{
  "name": "osprey-frontend-devtools",
  "description": "Dev-only JS toolchain (typecheck + tests) for OSPREY web interfaces. Not part of the Python wheel.",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test:js": "vitest run",
    "test:js:watch": "vitest",
    "lint": "eslint ."
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.0.5",
    "happy-dom": "^20.10.6",
    "eslint": "^9",
    "@eslint/js": "^9",
    "globals": "^17"
  }
}
