{
  "$description": "High Contrast Dark — WCAG-AAA member of the 'high-contrast' family (the dark twin of high-contrast-light.json). Same semantic key set as dark.json/light.json (contract-enforced). Every value aliases an EXISTING core.json primitive; no new primitives were needed to hit AAA. bg.primary/bg.terminal use the darkest existing slate step (slate.1100, #020408, already used elsewhere as wt-welcome.bg); text/accent use the lightest/brightest existing steps that clear the AAA gates with margin. AAA gates computed against these values (via validate.py's own contrast_ratio()) and ALL PASS: text.primary 19.82:1 (>=7), text.secondary 13.88:1 (>=7), text.muted 7.22:1 (>=4.5), accent.base 11.00:1 (>=4.5). accent.light/tint.accent/border.accent are re-derived from the brighter accent.light (teal.50, #67e8f9) chosen for this theme, not copy-pasted from dark.json's teal.100-based tints.",
  "$extensions": { "mode": "dark", "id": "high-contrast-dark", "label": "High Contrast Dark", "family": "high-contrast" },
  "bg": {
    "terminal": { "$value": "{color.slate.1100}", "$type": "color" },
    "primary": { "$value": "{color.slate.1100}", "$type": "color", "$description": "Darkest existing slate step (#020408); anchors the AAA gates below." },
    "secondary": { "$value": "{color.slate.1050}", "$type": "color" },
    "panel": { "$value": "{color.slate.1000}", "$type": "color" },
    "elevated": { "$value": "{color.slate.900}", "$type": "color" }
  },
  "text": {
    "primary": { "$value": "{color.slate.50}", "$type": "color", "$description": "Lightest existing slate step (#fafbfd); 19.82:1 vs bg.primary." },
    "secondary": { "$value": "{color.slate.500}", "$type": "color", "$description": "13.88:1 vs bg.primary." },
    "muted": { "$value": "{color.slate.600}", "$type": "color", "$description": "7.22:1 vs bg.primary — the dimmest existing slate step that still clears the AAA 4.5:1 floor (slate.650, dark.json's own text.muted value, only reaches 4.31:1 here and was rejected)." }
  },
  "accent": {
    "base": { "$value": "{color.teal.100}", "$type": "color", "$description": "11.00:1 vs bg.primary (AAA floor is 4.5:1)." },
    "light": { "$value": "{color.teal.50}", "$type": "color", "$description": "Brightest existing teal step; used as the base for tint.accent/border.accent below." },
    "on": { "$value": "#000000", "$type": "color", "$description": "Foreground for text/icons on accent.base fills (e.g. primary buttons). ~10.6:1 on teal.100 (white would be 1.87:1, far below the AAA 7:1 floor)." }
  },
  "amber": {
    "base": { "$value": "{color.amber.300}", "$type": "color" },
    "light": { "$value": "{color.amber.100}", "$type": "color" },
    "hover": { "$value": "{color.amber.500}", "$type": "color" }
  },
  "status": {
    "success": { "$value": "{color.green.400}", "$type": "color" },
    "warning": { "$value": "{color.amber.400}", "$type": "color" },
    "error": { "$value": "{color.red.300}", "$type": "color" },
    "error-hover": { "$value": "{color.red.500}", "$type": "color" }
  },
  "border": {
    "default": { "$value": "rgba(148, 163, 184, 0.12)", "$type": "color", "$description": "Same tint.neutral-family composite as dark.json's border.default (unaffected by the accent/text changes above)." },
    "accent": { "$value": "rgba(103, 232, 249, 0.15)", "$type": "color", "$description": "Alpha composite of THIS theme's accent.light (teal.50, #67e8f9) — not dark.json's teal.100-based value." }
  },
  "tint": {
