{
  "$description": "Apex Dark — gold-forward skin ported from tuning_scripts. The warm GOLD (#d4a574, core amber.300) is the focal/primary accent (accent.base/light + border.accent + all tint.accent.* carry gold), and the teal/cyan (#4fd1c5, core teal.100) is DEMOTED to the secondary/data slot: it lives in the amber.* group, tint.amber.*, chart.series slot 1, and the terminal cursor/selection. This inverts the 'osprey' family (where teal is accent and gold lives in amber.*). Surfaces are the tuning dark slate ramp; text is the tuning ink ramp; status/overlay/shadow/diff keep osprey's exact values. WCAG contract gates (text.primary/secondary >= 4.5, text.muted >= 3, accent >= 3, all vs bg.primary #0f172a) all pass with margin — text-primary ~16.3:1, text-secondary ~6.96:1, text-muted ~3.75:1, accent (gold) ~8.0:1. Zero nudges needed in dark.",
  "$extensions": { "mode": "dark", "id": "apex-dark", "label": "Apex Dark", "family": "apex" },
  "bg": {
    "terminal": { "$value": "#0a1120", "$type": "color", "$description": "Darkest surface — a shade below tuning --bg-0; not a core ramp step, kept literal." },
    "primary": { "$value": "#0f172a", "$type": "color", "$description": "tuning --bg-0; the main canvas and WCAG reference background. Not a core ramp step, kept literal." },
    "panel": { "$value": "#16203a", "$type": "color", "$description": "Intermediate surface between primary and secondary; not a core ramp step, kept literal." },
    "secondary": { "$value": "{color.slate.750}", "$type": "color", "$description": "tuning --bg-1 (#1e293b) — exact core alias." },
    "elevated": { "$value": "#334155", "$type": "color", "$description": "tuning --bg-2; lightest raised surface. Not a core ramp step, kept literal." }
  },
  "text": {
    "primary": { "$value": "{color.slate.250}", "$type": "color" },
    "secondary": { "$value": "{color.slate.550}", "$type": "color" },
    "muted": { "$value": "{color.slate.650}", "$type": "color" }
  },
  "accent": {
    "base": { "$value": "{color.amber.300}", "$type": "color", "$description": "GOLD-FORWARD: focal accent = warm gold #d4a574 (tuning --gold), aliased into core amber.300." },
    "light": { "$value": "{color.amber.100}", "$type": "color", "$description": "GOLD-FORWARD: lighter gold #e8c9a0 for hover/glow, aliased into core amber.100." },
    "on": { "$value": "{color.slate.1000}", "$type": "color", "$description": "GOLD-FORWARD: dark ink (#0a0f1a) on the light gold accent.base (#d4a574) = 8.61:1 — legible primary-button text (gated >= 4.5 vs accent.base)." }
  },
  "amber": {
    "base": { "$value": "{color.teal.100}", "$type": "color", "$description": "DEMOTED TEAL: the secondary/data hue #4fd1c5 (tuning --cyan) lives in the amber.* slot under the gold-forward inversion." },
    "light": { "$value": "{color.teal.50}", "$type": "color", "$description": "DEMOTED TEAL: brighter teal #67e8f9." },
    "hover": { "$value": "{color.teal.300}", "$type": "color", "$description": "DEMOTED TEAL: deeper teal #319795 for hover states." }
  },
  "status": {
    "success": { "$value": "{color.green.400}", "$type": "color" },
    "warning": { "$value": "{color.amber.400}", "$type": "color" },
    "error": { "$value": "{color.red.300}", "$type": "color" },
    "error-hover": { "$value": "{color.red.500}", "$type": "color" }
  },
  "border": {
    "default": { "$value": "rgba(148, 163, 184, 0.12)", "$type": "color", "$description": "Neutral alpha composite (#94a3b8) — not a solid ramp step, kept literal." },
    "accent": { "$value": "rgba(212, 165, 116, 0.15)", "$type": "color", "$description": "GOLD-FORWARD: alpha composite of the focal gold #d4a574 (tuning --gold, matching tuning's --gold-soft base rgb)." }
  },
  "tint": {
    "accent": {
      "04": { "$value": "rgba(212, 165, 116, 0.04)", "$type": "color" },
      "06": { "$value": "rgba(212, 165, 116, 0.06)", "$type": "color" },
      "08": { "$value": "rgba(212, 165, 116, 0.08)", "$type": "color" },
      "10": { "$value": "rgba(212, 165, 116, 0.10)", "$type": "color" },
      "12": { "$value": "rgba(212, 165, 116, 0.12)", "$type": "color" },
      "20": { "$value": "rgba(212, 165, 116, 0.20)", "$type": "color" },
      "25": { "$value": "rgba(212, 165, 116, 0.25)", "$type": "color" },
      "30": { "$value": "rgba(212, 165, 116, 0.30)", "$type": "color" }
    },
    "amber": {
      "04": { "$value": "rgba(79, 209, 197, 0.04)", "$type": "color" },
      "06": { "$value": "rgba(79, 209, 197, 0.06)", "$type": "color" },
      "08": { "$value": "rgba(79, 209, 197, 0.08)", "$type": "color" },
      "12": { "$value": "rgba(79, 209, 197, 0.12)", "$type": "color" },
      "15": { "$value": "rgba(79, 209, 197, 0.15)", "$type": "color" },
      "25": { "$value": "rgba(79, 209, 197, 0.25)", "$type": "color" }
    },
    "error": {
      "04": { "$value": "rgba(239, 68, 68, 0.04)", "$type": "color" },
      "08": { "$value": "rgba(239, 68, 68, 0.08)", "$type": "color" },
      "10": { "$value": "rgba(239, 68, 68, 0.10)", "$type": "color" },
      "15": { "$value": "rgba(239, 68, 68, 0.15)", "$type": "color" },
      "25": { "$value": "rgba(239, 68, 68, 0.25)", "$type": "color" },
      "30": { "$value": "rgba(239, 68, 68, 0.30)", "$type": "color" },
      "40": { "$value": "rgba(239, 68, 68, 0.40)", "$type": "color" }
    },
    "success": {
      "08": { "$value": "rgba(34, 197, 94, 0.08)", "$type": "color" },
      "40": { "$value": "rgba(34, 197, 94, 0.40)", "$type": "color" },
      "50": { "$value": "rgba(34, 197, 94, 0.50)", "$type": "color" }
    },
    "neutral": {
      "$description": "Base rgb(148,163,184) = color.slate.550 (tuning --ink-2).",
      "03": { "$value": "rgba(148, 163, 184, 0.03)", "$type": "color" },
      "06": { "$value": "rgba(148, 163, 184, 0.06)", "$type": "color" },
      "08": { "$value": "rgba(148, 163, 184, 0.08)", "$type": "color" },
      "10": { "$value": "rgba(148, 163, 184, 0.10)", "$type": "color" },
      "12": { "$value": "rgba(148, 163, 184, 0.12)", "$type": "color" },
      "20": { "$value": "rgba(148, 163, 184, 0.20)", "$type": "color" },
      "35": { "$value": "rgba(148, 163, 184, 0.35)", "$type": "color" }
    }
  },
  "overlay": {
    "black-20": { "$value": "rgba(0, 0, 0, 0.2)", "$type": "color" },
    "black-30": { "$value": "rgba(0, 0, 0, 0.3)", "$type": "color" },
    "black-40": { "$value": "rgba(0, 0, 0, 0.4)", "$type": "color" },
    "black-50": { "$value": "rgba(0, 0, 0, 0.5)", "$type": "color" },
    "black-60": { "$value": "rgba(0, 0, 0, 0.6)", "$type": "color" },
    "black-70": { "$value": "rgba(0, 0, 0, 0.7)", "$type": "color" },
    "white-03": { "$value": "rgba(255, 255, 255, 0.03)", "$type": "color" }
  },
  "shadow": {
    "panel": { "$value": "-4px 0 24px rgba(0, 0, 0, 0.4)", "$type": "shadow" },
    "dropdown": { "$value": "0 8px 24px rgba(0, 0, 0, 0.4)", "$type": "shadow" },
    "dialog": { "$value": "0 8px 32px rgba(0, 0, 0, 0.4)", "$type": "shadow" },
    "error-dialog": { "$value": "0 0 40px rgba(239, 68, 68, 0.15), 0 8px 32px rgba(0, 0, 0, 0.5)", "$type": "shadow" }
  },
  "diff": {
    "add-bg": { "$value": "rgba(34, 197, 94, 0.08)", "$type": "color" },
    "add-text": { "$value": "rgba(34, 197, 94, 0.9)", "$type": "color" },
    "del-bg": { "$value": "rgba(239, 68, 68, 0.08)", "$type": "color" },
    "del-text": { "$value": "rgba(239, 68, 68, 0.9)", "$type": "color" },
    "word-del-bg": { "$value": "rgba(239, 68, 68, 0.30)", "$type": "color" },
    "word-del-text": { "$value": "{color.red.300}", "$type": "color" },
    "word-add-bg": { "$value": "rgba(34, 197, 94, 0.30)", "$type": "color" },
    "word-add-text": { "$value": "{color.green.400}", "$type": "color" }
  },
  "terminal": {
    "cursor": { "$value": "{color.teal.100}", "$type": "color", "$description": "DEMOTED TEAL: cursor stays teal #4fd1c5 as a data cue." },
    "text": { "$value": "{color.slate.500}", "$type": "color" },
    "selection": { "$value": "rgba(79, 209, 197, 0.25)", "$type": "color", "$description": "DEMOTED TEAL: selection stays teal." },
    "ansi": {
      "background": { "$value": "#0a1120", "$type": "color", "$description": "= bg.terminal (literal)." },
      "foreground": { "$value": "{color.slate.500}", "$type": "color" },
      "cursor": { "$value": "{color.teal.100}", "$type": "color" },
      "cursor-accent": { "$value": "#0a1120", "$type": "color", "$description": "= bg.terminal (literal)." },
      "selection": { "$value": "rgba(79, 209, 197, 0.25)", "$type": "color" },
      "black": { "$value": "{color.slate.800}", "$type": "color" },
      "red": { "$value": "{color.red.300}", "$type": "color" },
      "green": { "$value": "{color.green.400}", "$type": "color" },
      "yellow": { "$value": "{color.amber.400}", "$type": "color" },
      "blue": { "$value": "{color.blue.300}", "$type": "color" },
      "magenta": { "$value": "{color.violet.300}", "$type": "color" },
      "cyan": { "$value": "{color.teal.100}", "$type": "color" },
      "white": { "$value": "{color.slate.400}", "$type": "color" },
      "bright-black": { "$value": "{color.slate.650}", "$type": "color" },
      "bright-red": { "$value": "{color.red.100}", "$type": "color" },
      "bright-green": { "$value": "{color.green.300}", "$type": "color" },
      "bright-yellow": { "$value": "{color.amber.200}", "$type": "color" },
      "bright-blue": { "$value": "{color.blue.100}", "$type": "color" },
      "bright-magenta": { "$value": "{color.violet.150}", "$type": "color" },
      "bright-cyan": { "$value": "{color.teal.50}", "$type": "color" },
      "bright-white": { "$value": "{color.slate.100}", "$type": "color" }
    }
  },
  "chart": {
    "$description": "paper/plot = bg.primary (tuning --bg-0 #0f172a); grid/axis-text = text.secondary family (#94a3b8). series slot 1 stays TEAL (the demoted data hue); the remaining five categorical slots are unchanged from the osprey palette.",
    "paper-bg": { "$value": "#0f172a", "$type": "color", "$description": "= bg.primary (literal)." },
    "plot-bg": { "$value": "#0f172a", "$type": "color", "$description": "= bg.primary (literal)." },
    "grid": { "$value": "rgba(148, 163, 184, 0.1)", "$type": "color", "$description": "text.secondary base (#94a3b8) at 10% alpha." },
    "axis-text": { "$value": "{color.slate.550}", "$type": "color" },
    "series": {
      "1": { "$value": "{color.teal.100}", "$type": "color", "$description": "DEMOTED TEAL survives as the primary data-series color." },
      "2": { "$value": "{color.amber.400}", "$type": "color" },
      "3": { "$value": "{color.green.400}", "$type": "color" },
      "4": { "$value": "{color.red.300}", "$type": "color" },
      "5": { "$value": "{color.violet.300}", "$type": "color" },
      "6": { "$value": "{color.blue.300}", "$type": "color" }
    }
  },
  "code": {
    "theme": { "$value": "highlight.js atom-one-dark theme", "$type": "string", "$description": "Must exactly match an asset 'name' in src/osprey/interfaces/vendor_manifest.json (contract-tested)." }
  }
}
