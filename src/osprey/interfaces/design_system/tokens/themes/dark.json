{
  "$description": "Dark theme — canonical values taken verbatim from web-terminal's variables.css (the hub, per proposal). Aliases are one-hop into core.json primitives; rgba/composite values that combine a base color with a specific alpha or a multi-part shadow are kept as literals (no ramp step encodes 'primitive + alpha', so a one-hop alias can't express them). WCAG contract gates (text.primary/secondary >= 4.5:1, text.muted >= 3:1, accent >= 3:1, all vs bg.primary) were computed against these values and ALL PASS with margin — dark text-primary 17.49:1, text-secondary 6.74:1, text-muted 4.03:1, accent 5.47:1. Zero nudges applied to this theme.",
  "$extensions": { "mode": "dark", "id": "dark", "label": "Dark", "family": "osprey", "default": true },
  "bg": {
    "terminal": { "$value": "{color.slate.1050}", "$type": "color" },
    "primary": { "$value": "{color.slate.1000}", "$type": "color" },
    "secondary": { "$value": "{color.slate.850}", "$type": "color" },
    "panel": { "$value": "{color.slate.900}", "$type": "color" },
    "elevated": { "$value": "{color.slate.800}", "$type": "color" }
  },
  "text": {
    "primary": { "$value": "{color.slate.250}", "$type": "color" },
    "secondary": { "$value": "{color.slate.600}", "$type": "color" },
    "muted": { "$value": "{color.slate.650}", "$type": "color" }
  },
  "accent": {
    "base": { "$value": "{color.teal.300}", "$type": "color" },
    "light": { "$value": "{color.teal.100}", "$type": "color" },
    "on": { "$value": "{color.slate.1000}", "$type": "color", "$description": "Foreground for text/icons on accent.base fills (e.g. primary buttons). 5.47:1 on teal.300." }
  },
  "amber": {
    "base": { "$value": "{color.amber.300}", "$type": "color" },
    "light": { "$value": "{color.amber.100}", "$type": "color" },
