{
  "$description": "Dark theme — remapped to the web-terminal redesign (Panel Designs frame 2a): a Grafana-style neutral canvas via the gray primitive family, a Grafana-blue accent (azure family — the working candidate; the final blue-vs-teal accent decision is deferred to the accent-decision-gate), and Grafana status colors. Solid colors are one-hop aliases into core.json; accent-derived alpha composites (accent tints, border.accent, terminal selection) were recomputed for the azure accent. Non-accent tint families neutral/error/success were re-based onto the new gray neutral and Grafana status primitives (consistency follow-up); tint.amber tracks the unchanged decorative-amber base. WCAG AA gates all pass vs bg.primary (#111217): text.primary 11.79:1, text.secondary 5.78:1, text.muted 3.71:1, accent 7.18:1, accent.on 7.18:1. Nudge: frame 2a's faint-text #565b64 scores only 2.74:1 on this very dark canvas (below the 3:1 floor), so text.muted uses the slightly lighter #6e6e77.",
  "$extensions": { "mode": "dark", "id": "dark", "label": "Dark", "family": "osprey", "default": true },
  "bg": {
    "terminal": { "$value": "{color.gray.900}", "$type": "color" },
    "primary": { "$value": "{color.gray.950}", "$type": "color" },
    "secondary": { "$value": "{color.gray.900}", "$type": "color" },
    "panel": { "$value": "{color.gray.850}", "$type": "color" },
    "elevated": { "$value": "{color.gray.800}", "$type": "color" }
  },
  "text": {
    "primary": { "$value": "{color.gray.250}", "$type": "color" },
    "secondary": { "$value": "{color.gray.400}", "$type": "color" },
    "muted": { "$value": "{color.gray.500}", "$type": "color", "$description": "WCAG nudge: frame 2a faint text #565b64 is 2.74:1 on bg.primary (below the 3:1 gate); gray.500 (#6e6e77) is 3.71:1." }
  },
  "accent": {
    "base": { "$value": "{color.azure.300}", "$type": "color" },
    "light": { "$value": "{color.azure.300}", "$type": "color", "$description": "Provisional = accent.base; frames specify only the base accent, the hover/light shade is deferred to the accent-decision-gate." },
    "on": { "$value": "{color.gray.950}", "$type": "color", "$description": "Foreground for text/icons on accent.base fills (e.g. primary buttons). 7.18:1 on azure.300." }
  },
  "amber": {
    "base": { "$value": "{color.amber.300}", "$type": "color" },
    "light": { "$value": "{color.amber.100}", "$type": "color" },
    "hover": { "$value": "{color.amber.500}", "$type": "color" }
  },
  "status": {
    "success": { "$value": "{color.green.350}", "$type": "color" },
    "warning": { "$value": "{color.amber.350}", "$type": "color" },
    "error": { "$value": "{color.red.400}", "$type": "color" },
    "error-hover": { "$value": "{color.red.500}", "$type": "color", "$description": "Darker/more-saturated red than status.error (#e05454) for hover." }
  },
  "border": {
    "default": { "$value": "{color.gray.700}", "$type": "color", "$description": "Frame 2a hairline border #2c3235 — a solid ramp step now (was an alpha composite in the prior skin)." },
    "accent": { "$value": "rgba(110, 159, 255, 0.15)", "$type": "color", "$description": "Alpha composite of the accent (#6e9fff)." }
  },
  "tint": {
    "accent": {
      "04": { "$value": "rgba(110, 159, 255, 0.04)", "$type": "color" },
      "06": { "$value": "rgba(110, 159, 255, 0.06)", "$type": "color" },
      "08": { "$value": "rgba(110, 159, 255, 0.08)", "$type": "color" },
      "10": { "$value": "rgba(110, 159, 255, 0.10)", "$type": "color" },
      "12": { "$value": "rgba(110, 159, 255, 0.12)", "$type": "color" },
      "20": { "$value": "rgba(110, 159, 255, 0.20)", "$type": "color" },
      "25": { "$value": "rgba(110, 159, 255, 0.25)", "$type": "color" },
      "30": { "$value": "rgba(110, 159, 255, 0.30)", "$type": "color" }
    },
    "amber": {
      "04": { "$value": "rgba(212, 165, 116, 0.04)", "$type": "color" },
      "06": { "$value": "rgba(212, 165, 116, 0.06)", "$type": "color" },
      "08": { "$value": "rgba(212, 165, 116, 0.08)", "$type": "color" },
      "12": { "$value": "rgba(212, 165, 116, 0.12)", "$type": "color" },
      "15": { "$value": "rgba(212, 165, 116, 0.15)", "$type": "color" },
      "25": { "$value": "rgba(212, 165, 116, 0.25)", "$type": "color" }
    },
    "error": {
      "$description": "Base rgb(224,84,84) = status.error #e05454 (Grafana red), re-based from the prior #ef4444 so error tints track the current status color.",
      "04": { "$value": "rgba(224, 84, 84, 0.04)", "$type": "color" },
      "08": { "$value": "rgba(224, 84, 84, 0.08)", "$type": "color" },
      "10": { "$value": "rgba(224, 84, 84, 0.10)", "$type": "color" },
      "15": { "$value": "rgba(224, 84, 84, 0.15)", "$type": "color" },
      "25": { "$value": "rgba(224, 84, 84, 0.25)", "$type": "color" },
      "30": { "$value": "rgba(224, 84, 84, 0.30)", "$type": "color" },
      "40": { "$value": "rgba(224, 84, 84, 0.40)", "$type": "color" }
    },
    "success": {
      "$description": "Base rgb(115,191,105) = status.success #73bf69 (Grafana green), re-based from the prior #22c55e so success tints track the current status color.",
      "08": { "$value": "rgba(115, 191, 105, 0.08)", "$type": "color" },
      "40": { "$value": "rgba(115, 191, 105, 0.40)", "$type": "color" },
      "50": { "$value": "rgba(115, 191, 105, 0.50)", "$type": "color" }
    },
    "neutral": {
      "$description": "Base rgb(163,164,166) = color.gray.300, re-based from the retired blue-slate (slate.550) onto the new gray neutral at ~the same lightness — consistency follow-up so no tint derives from a retired primitive.",
      "03": { "$value": "rgba(163, 164, 166, 0.03)", "$type": "color" },
      "06": { "$value": "rgba(163, 164, 166, 0.06)", "$type": "color" },
      "08": { "$value": "rgba(163, 164, 166, 0.08)", "$type": "color" },
      "10": { "$value": "rgba(163, 164, 166, 0.10)", "$type": "color" },
      "12": { "$value": "rgba(163, 164, 166, 0.12)", "$type": "color" },
      "20": { "$value": "rgba(163, 164, 166, 0.20)", "$type": "color" },
      "35": { "$value": "rgba(163, 164, 166, 0.35)", "$type": "color" }
    }
  },
  "overlay": {
    "black-20": { "$value": "rgba(0, 0, 0, 0.2)", "$type": "color" },
    "black-30": { "$value": "rgba(0, 0, 0, 0.3)", "$type": "color" },
    "black-40": { "$value": "rgba(0, 0, 0, 0.4)", "$type": "color" },
    "black-50": { "$value": "rgba(0, 0, 0, 0.5)", "$type": "color" },
    "black-60": { "$value": "rgba(0, 0, 0, 0.6)", "$type": "color" },
    "black-70": { "$value": "rgba(0, 0, 0, 0.7)", "$type": "color" },
    "white-03": { "$value": "rgba(255, 255, 255, 0.03)", "$type": "color" }
  },
  "shadow": {
    "panel": { "$value": "-4px 0 24px rgba(0, 0, 0, 0.4)", "$type": "shadow" },
    "dropdown": { "$value": "0 8px 24px rgba(0, 0, 0, 0.4)", "$type": "shadow" },
    "dialog": { "$value": "0 8px 32px rgba(0, 0, 0, 0.4)", "$type": "shadow" },
    "error-dialog": { "$value": "0 0 40px rgba(239, 68, 68, 0.15), 0 8px 32px rgba(0, 0, 0, 0.5)", "$type": "shadow" }
  },
  "diff": {
    "add-bg": { "$value": "rgba(34, 197, 94, 0.08)", "$type": "color" },
    "add-text": { "$value": "rgba(34, 197, 94, 0.9)", "$type": "color" },
    "del-bg": { "$value": "rgba(239, 68, 68, 0.08)", "$type": "color" },
    "del-text": { "$value": "rgba(239, 68, 68, 0.9)", "$type": "color" },
    "word-del-bg": { "$value": "rgba(239, 68, 68, 0.30)", "$type": "color" },
    "word-del-text": { "$value": "{color.red.300}", "$type": "color" },
    "word-add-bg": { "$value": "rgba(34, 197, 94, 0.30)", "$type": "color" },
    "word-add-text": { "$value": "{color.green.400}", "$type": "color" }
  },
  "terminal": {
    "cursor": { "$value": "{color.azure.300}", "$type": "color" },
    "text": { "$value": "{color.gray.250}", "$type": "color" },
    "selection": { "$value": "rgba(110, 159, 255, 0.25)", "$type": "color" },
    "ansi": {
      "background": { "$value": "{color.gray.900}", "$type": "color" },
      "foreground": { "$value": "{color.gray.250}", "$type": "color" },
      "cursor": { "$value": "{color.azure.300}", "$type": "color" },
      "cursor-accent": { "$value": "{color.gray.900}", "$type": "color" },
      "selection": { "$value": "rgba(110, 159, 255, 0.25)", "$type": "color" },
      "black": { "$value": "{color.gray.850}", "$type": "color" },
      "red": { "$value": "{color.red.400}", "$type": "color" },
      "green": { "$value": "{color.green.350}", "$type": "color" },
      "yellow": { "$value": "{color.amber.350}", "$type": "color" },
      "blue": { "$value": "{color.blue.300}", "$type": "color" },
      "magenta": { "$value": "{color.violet.250}", "$type": "color" },
      "cyan": { "$value": "{color.teal.100}", "$type": "color" },
      "white": { "$value": "{color.gray.250}", "$type": "color" },
      "bright-black": { "$value": "{color.gray.600}", "$type": "color" },
      "bright-red": { "$value": "{color.red.100}", "$type": "color" },
      "bright-green": { "$value": "{color.green.300}", "$type": "color" },
      "bright-yellow": { "$value": "{color.amber.200}", "$type": "color" },
      "bright-blue": { "$value": "{color.blue.100}", "$type": "color" },
      "bright-magenta": { "$value": "{color.violet.150}", "$type": "color" },
      "bright-cyan": { "$value": "{color.teal.50}", "$type": "color" },
      "bright-white": { "$value": "{color.gray.50}", "$type": "color" }
    }
  },
  "chart": {
    "$description": "Plot backgrounds, grid, and axis text follow the new neutral theme (paper/plot = bg.primary; grid/axis = the new text.secondary family). The 6-slot categorical series palette is left as the prior distinguishable set — it is a stand-alone categorical palette, not bound to the UI accent, so it is not re-tinted here.",
    "paper-bg": { "$value": "{color.gray.950}", "$type": "color" },
    "plot-bg": { "$value": "{color.gray.950}", "$type": "color" },
    "grid": { "$value": "rgba(142, 142, 154, 0.1)", "$type": "color", "$description": "text.secondary base (#8e8e9a) at 10% alpha." },
    "axis-text": { "$value": "{color.gray.400}", "$type": "color" },
    "series": {
      "1": { "$value": "{color.teal.100}", "$type": "color" },
      "2": { "$value": "{color.amber.400}", "$type": "color" },
      "3": { "$value": "{color.green.400}", "$type": "color" },
      "4": { "$value": "{color.red.300}", "$type": "color" },
      "5": { "$value": "{color.violet.300}", "$type": "color" },
      "6": { "$value": "{color.blue.300}", "$type": "color" }
    }
  },
  "code": {
    "theme": { "$value": "highlight.js atom-one-dark theme", "$type": "string", "$description": "Must exactly match an asset 'name' in src/osprey/interfaces/vendor_manifest.json (contract-tested)." }
  }
}
