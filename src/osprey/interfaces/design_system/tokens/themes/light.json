{
  "$description": "Light theme ('Lab Instrument Panel') — remapped to the web-terminal redesign (Panel Designs frame 2c): a grey canvas (#f4f5f5) with white panel cards (#fafbfc), a Grafana-blue accent (azure family — working candidate, final blue-vs-teal decision deferred to the accent-decision-gate), and Grafana status colors. Same key set as dark.json (contract-enforced). Solid colors are one-hop aliases into core.json; accent-derived composites recomputed for the azure accent (accent tints + border.accent as rgba; terminal selection uses the azure.50 solid tint #e8f1fb per frame 2c); non-accent tint families neutral/error/success re-based onto the new gray neutral and Grafana status primitives (consistency follow-up); tint.amber tracks the unchanged decorative-amber base. WCAG AA gates all pass vs bg.primary (#f4f5f5): text.primary 13.43:1, text.secondary 4.62:1, text.muted 3.27:1, accent 5.34:1, accent.on 5.63:1. Nudge: frame 2c's muted #a3a4a6 scores only 2.28:1 on this light canvas (below the 3:1 floor), so text.muted uses the darker #86878f.",
  "$extensions": { "mode": "light", "id": "light", "label": "Light", "family": "osprey" },
  "bg": {
    "terminal": { "$value": "{color.gray.50}", "$type": "color" },
    "primary": { "$value": "{color.gray.100}", "$type": "color" },
    "secondary": { "$value": "{color.gray.150}", "$type": "color" },
    "panel": { "$value": "{color.gray.50}", "$type": "color" },
    "elevated": { "$value": "{color.gray.150}", "$type": "color" }
  },
  "text": {
    "primary": { "$value": "{color.gray.750}", "$type": "color" },
    "secondary": { "$value": "{color.gray.500}", "$type": "color" },
    "muted": { "$value": "{color.gray.350}", "$type": "color", "$description": "WCAG nudge: frame 2c muted #a3a4a6 is 2.28:1 on bg.primary (below the 3:1 gate); gray.350 (#86878f) is 3.27:1." }
  },
  "accent": {
    "base": { "$value": "{color.azure.500}", "$type": "color" },
    "light": { "$value": "{color.azure.500}", "$type": "color", "$description": "Provisional = accent.base; frames specify only the base accent, the hover/light shade is deferred to the accent-decision-gate." },
    "on": { "$value": "{color.gray.50}", "$type": "color", "$description": "Foreground for text/icons on accent.base fills (e.g. primary buttons). 5.63:1 on azure.500." }
  },
  "amber": {
    "base": { "$value": "{color.amber.800}", "$type": "color" },
    "light": { "$value": "{color.amber.900}", "$type": "color" },
    "hover": { "$value": "{color.amber.700}", "$type": "color" }
  },
  "status": {
    "success": { "$value": "{color.green.550}", "$type": "color" },
    "warning": { "$value": "{color.amber.750}", "$type": "color" },
    "error": { "$value": "{color.red.600}", "$type": "color" },
    "error-hover": { "$value": "{color.red.700}", "$type": "color", "$description": "Darker red than status.error (#c4162a) for hover." }
  },
  "border": {
    "default": { "$value": "{color.gray.200}", "$type": "color", "$description": "Frame 2c hairline border #d8d9da — a solid ramp step." },
    "accent": { "$value": "rgba(31, 98, 196, 0.25)", "$type": "color", "$description": "Alpha composite of the accent (#1f62c4)." }
  },
  "tint": {
    "accent": {
      "04": { "$value": "rgba(31, 98, 196, 0.04)", "$type": "color" },
      "06": { "$value": "rgba(31, 98, 196, 0.06)", "$type": "color" },
      "08": { "$value": "rgba(31, 98, 196, 0.08)", "$type": "color" },
      "10": { "$value": "rgba(31, 98, 196, 0.10)", "$type": "color" },
      "12": { "$value": "rgba(31, 98, 196, 0.12)", "$type": "color" },
      "20": { "$value": "rgba(31, 98, 196, 0.20)", "$type": "color" },
      "25": { "$value": "rgba(31, 98, 196, 0.25)", "$type": "color" },
      "30": { "$value": "rgba(31, 98, 196, 0.30)", "$type": "color" }
    },
    "amber": {
      "04": { "$value": "rgba(160, 112, 64, 0.04)", "$type": "color" },
      "06": { "$value": "rgba(160, 112, 64, 0.06)", "$type": "color" },
      "08": { "$value": "rgba(160, 112, 64, 0.08)", "$type": "color" },
      "12": { "$value": "rgba(160, 112, 64, 0.12)", "$type": "color" },
      "15": { "$value": "rgba(160, 112, 64, 0.15)", "$type": "color" },
      "25": { "$value": "rgba(160, 112, 64, 0.25)", "$type": "color" }
    },
    "error": {
      "$description": "Base rgb(196,22,42) = status.error #c4162a (Grafana red), re-based from the prior #dc2626 so error tints track the current status color.",
      "04": { "$value": "rgba(196, 22, 42, 0.04)", "$type": "color" },
      "08": { "$value": "rgba(196, 22, 42, 0.08)", "$type": "color" },
      "10": { "$value": "rgba(196, 22, 42, 0.10)", "$type": "color" },
      "15": { "$value": "rgba(196, 22, 42, 0.15)", "$type": "color" },
      "25": { "$value": "rgba(196, 22, 42, 0.25)", "$type": "color" },
      "30": { "$value": "rgba(196, 22, 42, 0.30)", "$type": "color" },
      "40": { "$value": "rgba(196, 22, 42, 0.40)", "$type": "color" }
    },
    "success": {
      "$description": "Base rgb(86,166,75) = status.success #56a64b (Grafana green), re-based from the prior #16a34a so success tints track the current status color.",
      "08": { "$value": "rgba(86, 166, 75, 0.08)", "$type": "color" },
      "40": { "$value": "rgba(86, 166, 75, 0.40)", "$type": "color" },
      "50": { "$value": "rgba(86, 166, 75, 0.50)", "$type": "color" }
    },
    "neutral": {
      "$description": "Base rgb(110,110,119) = color.gray.500, re-based from the retired blue-slate (slate.650) onto the new gray neutral at ~the same lightness — consistency follow-up so no tint derives from a retired primitive.",
      "03": { "$value": "rgba(110, 110, 119, 0.03)", "$type": "color" },
      "06": { "$value": "rgba(110, 110, 119, 0.06)", "$type": "color" },
      "08": { "$value": "rgba(110, 110, 119, 0.08)", "$type": "color" },
      "10": { "$value": "rgba(110, 110, 119, 0.10)", "$type": "color" },
      "12": { "$value": "rgba(110, 110, 119, 0.12)", "$type": "color" },
      "20": { "$value": "rgba(110, 110, 119, 0.20)", "$type": "color" },
      "35": { "$value": "rgba(110, 110, 119, 0.35)", "$type": "color" }
    }
  },
  "overlay": {
    "$description": "Non-monotonic alphas (black-30 < black-20; black-60 < black-50) are preserved exactly as hand-tuned in theme-light.css, not 'corrected'.",
    "black-20": { "$value": "rgba(0, 0, 0, 0.06)", "$type": "color" },
    "black-30": { "$value": "rgba(0, 0, 0, 0.05)", "$type": "color" },
    "black-40": { "$value": "rgba(0, 0, 0, 0.08)", "$type": "color" },
    "black-50": { "$value": "rgba(0, 0, 0, 0.15)", "$type": "color" },
    "black-60": { "$value": "rgba(0, 0, 0, 0.10)", "$type": "color" },
    "black-70": { "$value": "rgba(0, 0, 0, 0.25)", "$type": "color" },
    "white-03": { "$value": "rgba(255, 255, 255, 0.5)", "$type": "color", "$description": "Same token name as dark's white-03 but a very different alpha (0.5 vs 0.03) in source — light theme repurposes this slot; preserved as-is." }
  },
  "shadow": {
    "panel": { "$value": "-2px 0 8px rgba(0, 0, 0, 0.08)", "$type": "shadow" },
    "dropdown": { "$value": "0 4px 12px rgba(0, 0, 0, 0.1)", "$type": "shadow" },
    "dialog": { "$value": "0 4px 16px rgba(0, 0, 0, 0.12)", "$type": "shadow" },
    "error-dialog": { "$value": "0 4px 16px rgba(220, 38, 38, 0.1), 0 4px 16px rgba(0, 0, 0, 0.1)", "$type": "shadow" }
  },
  "diff": {
    "add-bg": { "$value": "rgba(22, 163, 74, 0.1)", "$type": "color" },
    "add-text": { "$value": "{color.green.700}", "$type": "color" },
    "del-bg": { "$value": "rgba(220, 38, 38, 0.1)", "$type": "color" },
    "del-text": { "$value": "{color.red.500}", "$type": "color" },
    "word-del-bg": { "$value": "rgba(220, 38, 38, 0.20)", "$type": "color" },
    "word-del-text": { "$value": "{color.red.700}", "$type": "color" },
    "word-add-bg": { "$value": "rgba(22, 163, 74, 0.20)", "$type": "color" },
    "word-add-text": { "$value": "{color.green.800}", "$type": "color" }
  },
  "terminal": {
    "cursor": { "$value": "{color.azure.500}", "$type": "color" },
    "text": { "$value": "{color.gray.750}", "$type": "color" },
    "selection": { "$value": "{color.azure.50}", "$type": "color", "$description": "Frame 2c selection tint #e8f1fb — a solid pre-composited light accent tint." },
    "ansi": {
      "background": { "$value": "{color.gray.50}", "$type": "color" },
      "foreground": { "$value": "{color.gray.750}", "$type": "color" },
      "cursor": { "$value": "{color.azure.500}", "$type": "color" },
      "cursor-accent": { "$value": "{color.gray.50}", "$type": "color" },
      "selection": { "$value": "{color.azure.50}", "$type": "color" },
      "black": { "$value": "{color.gray.150}", "$type": "color" },
      "red": { "$value": "{color.red.600}", "$type": "color" },
      "green": { "$value": "{color.green.550}", "$type": "color" },
      "yellow": { "$value": "{color.amber.750}", "$type": "color" },
      "blue": { "$value": "{color.blue.500}", "$type": "color" },
      "magenta": { "$value": "{color.violet.450}", "$type": "color" },
      "cyan": { "$value": "{color.teal.500}", "$type": "color" },
      "white": { "$value": "{color.gray.750}", "$type": "color" },
      "bright-black": { "$value": "{color.gray.300}", "$type": "color" },
      "bright-red": { "$value": "{color.red.300}", "$type": "color" },
      "bright-green": { "$value": "{color.green.400}", "$type": "color" },
      "bright-yellow": { "$value": "{color.amber.400}", "$type": "color" },
      "bright-blue": { "$value": "{color.blue.300}", "$type": "color" },
      "bright-magenta": { "$value": "{color.violet.300}", "$type": "color" },
      "bright-cyan": { "$value": "{color.teal.400}", "$type": "color" },
      "bright-white": { "$value": "{color.gray.950}", "$type": "color" }
    }
  },
  "chart": {
    "$description": "Plot backgrounds, grid, and axis text follow the new neutral theme (paper/plot = bg.primary; grid/axis = the new text.secondary family). The 6-slot categorical series palette is left as the prior distinguishable set — a stand-alone categorical palette, not bound to the UI accent, so not re-tinted here.",
    "paper-bg": { "$value": "{color.gray.100}", "$type": "color" },
    "plot-bg": { "$value": "{color.gray.100}", "$type": "color" },
    "grid": { "$value": "rgba(110, 110, 119, 0.1)", "$type": "color", "$description": "text.secondary base (#6e6e77) at 10% alpha, mirroring dark's grid formula." },
    "axis-text": { "$value": "{color.gray.500}", "$type": "color" },
    "series": {
      "1": { "$value": "{color.teal.400}", "$type": "color" },
      "2": { "$value": "{color.amber.600}", "$type": "color" },
      "3": { "$value": "{color.green.700}", "$type": "color" },
      "4": { "$value": "{color.red.500}", "$type": "color" },
      "5": { "$value": "{color.violet.500}", "$type": "color" },
      "6": { "$value": "{color.blue.500}", "$type": "color" }
    }
  },
  "code": {
    "theme": { "$value": "highlight.js atom-one-light theme", "$type": "string", "$description": "Must exactly match an asset 'name' in src/osprey/interfaces/vendor_manifest.json (contract-tested)." }
  }
}
