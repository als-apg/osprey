; Grafana configuration — generated by OSPREY
; Do not edit; re-generated on each launch.

[server]
http_addr = {{ grafana_host }}
http_port = {{ grafana_port }}
serve_from_sub_path = false

[security]
allow_embedding = true

[auth.anonymous]
enabled = true
org_role = Viewer

[paths]
data = {{ data_base }}/grafana/data
logs = {{ data_base }}/logs
provisioning = {{ data_base }}/grafana/provisioning

[dashboards]
min_refresh_interval = 5s
default_home_dashboard_path = {{ data_base }}/grafana/dashboards/claude-code-overview.json

[log]
mode = file
level = warn

; --- Simplify UI for embedded use ---

[explore]
enabled = false

[alerting]
enabled = false

[unified_alerting]
enabled = false

[news]
news_feed_enabled = false

[help]
enabled = false

[profile]
enabled = false
