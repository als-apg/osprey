# OTEL Collector configuration — generated by OSPREY
# Do not edit; re-generated on each launch.

receivers:
  otlp:
    protocols:
      grpc:
        endpoint: "{{ otel_host }}:{{ otel_grpc_port }}"
      http:
        endpoint: "{{ otel_host }}:{{ otel_http_port }}"

  # Host-level system metrics (CPU, memory, disk, network)
  hostmetrics:
    collection_interval: 15s
    scrapers:
      cpu:
        metrics:
          system.cpu.utilization:
            enabled: true
      memory:
        metrics:
          system.memory.utilization:
            enabled: true
      disk: {}
      load: {}
      network: {}
      process:
        include:
          match_type: regexp
          names: ["claude", "python.*osprey", "node", "prometheus", "otelcol", "grafana"]
        mute_process_exe_error: true
        mute_process_io_error: true
        mute_process_user_error: true

processors:
  memory_limiter:
    limit_mib: 512
    check_interval: 5s
  batch:
    timeout: 1s
    send_batch_size: 1024

exporters:
  prometheus:
    endpoint: "{{ otel_host }}:{{ otel_prometheus_port }}"
    resource_to_telemetry_conversion:
      enabled: true
  debug:
    verbosity: basic

extensions:
  health_check:
    endpoint: "{{ otel_host }}:13133"

service:
  extensions: [health_check]
  pipelines:
    metrics:
      receivers: [otlp, hostmetrics]
      processors: [memory_limiter, batch]
      exporters: [prometheus]
    logs:
      receivers: [otlp]
      processors: [memory_limiter, batch]
      exporters: [debug]
