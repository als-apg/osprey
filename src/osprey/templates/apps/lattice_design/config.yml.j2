# ============================================================
# {{ project_name }} Configuration
# ============================================================
# Lattice Physics Design
# Interactive accelerator optics with Accelerator Toolbox (AT)
# ============================================================

# Project identity
project_name: "{{ project_name }}"

build_dir: ./build

# Root directory (absolute path)
project_root: {{ project_root }}

# ============================================================
# API CONFIGURATION
# ============================================================
# API keys and endpoints for LLM providers

api:
  providers:
    cborg:
      api_key: ${CBORG_API_KEY}
      base_url: https://api.cborg.lbl.gov/v1
      models:                        # Model IDs as named by this provider
        haiku: anthropic/claude-haiku
        sonnet: anthropic/claude-sonnet
        opus: anthropic/claude-opus
    amsc:
      api_key: ${AMSC_I2_API_KEY}
      base_url: https://api.i2-core.american-science-cloud.org/v1
    stanford:
      api_key: ${STANFORD_API_KEY}
      base_url: https://aiapi-prod.stanford.edu/v1
    openai:
      api_key: ${OPENAI_API_KEY}
      base_url: https://api.openai.com/v1
    anthropic:
      api_key: ${ANTHROPIC_API_KEY}
      base_url: https://api.anthropic.com
      models:
        haiku: claude-haiku-4-5-20251001
        sonnet: claude-sonnet-4-5-20250929
        opus: claude-opus-4-6
    google:
      api_key: ${GOOGLE_API_KEY}
      base_url: https://generativelanguage.googleapis.com/v1beta
    ollama:
      api_key: ollama
      base_url: ${OLLAMA_HOST:-http://localhost:11434}
      host: localhost
      port: 11434
    argo:
      api_key: ${ARGO_API_KEY}
      base_url: https://argo-bridge.cels.anl.gov
    als-apg:
      api_key: ${ALS_APG_API_KEY}
      base_url: https://llm.gianlucamartino.com/v1
      models:
        haiku: claude-haiku-4-5-20251001
        sonnet: claude-sonnet-4-6
        opus: claude-opus-4-6

# ============================================================
# ENVIRONMENT VARIABLES
# ============================================================
# Set these in your .env file:
#
#   CBORG_API_KEY=your-cborg-key
#   OPENAI_API_KEY=sk-...
#   ANTHROPIC_API_KEY=sk-ant-...
#   TZ=UTC

# ============================================================
# EXECUTION INFRASTRUCTURE
# ============================================================

execution:
  execution_method: "local"
  python_env_path: {{ current_python_env }}
  code_generator: "{{ code_generator | default('basic') }}"

# ============================================================
# SYSTEM CONFIGURATION
# ============================================================

system:
  timezone: ${TZ:-UTC}

file_paths:
  agent_data_dir: _agent_data
  executed_python_scripts_dir: executed_scripts
  user_memory_dir: user_memory
  api_calls_dir: api_calls

# ============================================================
# WORKSPACE & ARTIFACT GALLERY
# ============================================================

workspace:
  base_dir: "./osprey-workspace"

artifact_server:
  host: "127.0.0.1"
  port: 8086
  auto_launch: true

# ============================================================
# KARMA — Claude Code Analytics Dashboard
# ============================================================

karma:
  host: "127.0.0.1"
  port: 8741
  auto_launch: true

# ============================================================
# LATTICE DASHBOARD
# ============================================================
# Live visualization of lattice optics, resonance diagrams,
# chromaticity, tune footprint, dynamic aperture, and frequency maps.

lattice_dashboard:
  host: "127.0.0.1"
  port: 8097
  auto_launch: true

# ============================================================
# WEB PANEL CONFIGURATION
# ============================================================
# Controls which panel tabs appear in the web terminal (osprey web).
# Universal panels (Workspace, Activity, Session Analytics) are always shown.

web:
  panels:
    lattice: true

# ============================================================
# CLAUDE CODE INTEGRATION
# ============================================================

claude_code:
  servers:
    controls: {enabled: false}
    ariel: {enabled: false}
    channel-finder: {enabled: false}
    matlab: {enabled: false}
    confluence: {enabled: false}
  agents:
    logbook-search: {enabled: false}
    logbook-deep-research: {enabled: false}
    wiki-search: {enabled: false}
    matlab-search: {enabled: false}
    graph-analyst: {enabled: false}
  provider: {{ default_provider | default("anthropic") }}
  default_model: {{ default_model | default("haiku") }}
