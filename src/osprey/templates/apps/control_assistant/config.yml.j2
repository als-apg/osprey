# File paths - Data storage organization
file_paths:
  agent_data_dir: _agent_data
  executed_python_scripts_dir: executed_scripts
  user_memory_dir: user_memory
  api_calls_dir: api_calls

# ============================================================
# ARIEL - Electronic Logbook Search
# ============================================================
# ARIEL provides semantic search over electronic logbooks.
# Configure the logbook source and search/embedding options below.
#
# Provider credentials are defined in api.providers section above.
# ARIEL references providers by name (e.g., "ollama", "cborg").

ariel:
  database:
    uri: postgresql://ariel:ariel@localhost:5432/ariel

  default_max_results: 10

  # Ingestion - demo logbook data (bundled with template)
  # For production: change adapter and source_url to your logbook system
  ingestion:
    adapter: generic_json
    source_url: data/logbook_seed/demo_logbook.json

  # Search modules (leaf-level search functions)
  # provider: references api.providers for credentials (api_key, base_url)
  # Both keyword and semantic are enabled by default.
  # If Ollama/pgvector are unavailable, ARIEL degrades gracefully to keyword-only.
  search_modules:
    keyword:
      enabled: true
    semantic:
      enabled: true      # Degrades gracefully if Ollama/pgvector unavailable
      provider: ollama    # References api.providers.ollama
      model: nomic-embed-text

  # Pipelines (compose search modules into higher-level strategies)
  # retrieval_modules: which search modules each pipeline uses
  pipelines:
    rag:
      enabled: true
      retrieval_modules: [keyword, semantic]  # Semantic auto-disabled if unavailable

  # Enhancement modules
  # provider: references api.providers for credentials
  enhancement_modules:
    # Semantic processor: LLM-based keyword extraction and summarization
    # Enables better keyword search and RAG context
    semantic_processor:
      enabled: false  # Requires LLM API calls. Enable for better search quality.
      provider: {{ default_provider }}  # References api.providers
      model:
        provider: {{ default_provider }}
        model_id: {{ default_model }}
        max_tokens: 256

    # Text embedding: Vector embeddings for semantic search
    # Degrades gracefully if Ollama or pgvector is unavailable
    text_embedding:
      enabled: true   # Degrades gracefully if Ollama/pgvector unavailable
      provider: ollama  # References api.providers.ollama
      models:
        - name: nomic-embed-text
          dimension: 768

  # Default embedding provider (fallback for modules without explicit provider)
  embedding:
    provider: ollama

  # ReAct agent configuration
  # provider: references api.providers for credentials (api_key, base_url)
  reasoning:
    provider: cborg  # References api.providers.cborg for credentials
    model_id: haiku
    max_iterations: 5
    temperature: 0.1
    total_timeout_seconds: 120

# ============================================================
# LOGBOOK COMPOSITION
# ============================================================
# LLM settings for the logbook compose panel in the artifact gallery.
# provider: references api.providers for credentials (api_key, base_url)
# default_tier: which model tier to use when operator doesn't choose one
# The operator can override the tier (haiku/sonnet/opus) from the UI;
# the tier is mapped to a model_id via api.providers[provider].models.

logbook:
  composition:
    provider: {{ default_provider | default("anthropic") }}
    model_id: {{ default_model | default("haiku") }}
    default_tier: haiku   # Options: haiku | sonnet | opus

# ============================================================
# WORKSPACE & ARTIFACT GALLERY
# ============================================================
# Working directory for artifacts, data context, screenshots, etc.
# Resolved relative to this config file's directory (project root).

workspace:
  base_dir: "./osprey-workspace"

# Artifact gallery web server (auto-launches on first artifact save)
artifact_server:
  host: "127.0.0.1"
  port: 8086
  auto_launch: true

# ============================================================
# DEPLOT — Graph Data Extraction Service
# ============================================================
# DePlot extracts numerical data from chart/graph images using
# Google's Pix2Struct model. Auto-launches with `osprey web`.
# Requires: uv sync --extra graph (first run downloads ~1GB model)

deplot:
  host: "127.0.0.1"
  port: 8095
  auto_launch: true

# ============================================================
# AGENTSVIEW — Session Analytics UI
# ============================================================
# Provides a web UI for browsing Claude Code session transcripts,
# analytics dashboards, and full-text search over session history.
# Install: go install github.com/wesm/agentsview@latest
# Sessions are automatically scoped to this project directory.

agentsview:
  host: "127.0.0.1"
  port: 8096
  auto_launch: true
  project: "{{ project_name | replace('-', '_') }}"

# ============================================================
# CONFLUENCE WIKI
# ============================================================
# Confluence wiki URL for the external link button in the web terminal
# header and for the mcp-atlassian MCP tools.
# Set CONFLUENCE_ACCESS_TOKEN in your .env file for MCP tool access.

confluence:
  url: "https://commons.lbl.gov"
  default_page: "spaces/AAP/pages/351993894/ALS+Injector+wiki+toy+example"
  # default_space: ""  # Optional: default space key to filter searches

# ============================================================
# MATLAB MIDDLE LAYER (MML) CODEBASE
# ============================================================
# MML function database for the matlab-search agent.
# Provides function lookup, dependency graphs, and source code search
# across the MATLAB Middle Layer codebase.
#
# Index with: python -m osprey.mcp_server.matlab index \
#   --data-file /path/to/matlab_dependencies.json
# Override DB path via MATLAB_MML_DB env var.

matlab:
  db_path: ~/.matlab-mml/mml.db

# ============================================================
# ACCELPAPERS — Literature Search (Typesense)
# ============================================================
# AccelPapers uses Typesense for hybrid BM25 + vector search over
# accelerator physics papers from INSPIRE. Configuration is env-var driven;
# this section is for reference only.
#
# Setup:
#   1. Install Typesense 27.1:  brew install typesense/tap/typesense-server@27.1
#      (28.0+ has a regression with OpenAI-compatible auto-embedding)
#   2. Start server:            ./scripts/start_typesense.sh
#   3. Start Ollama:            ollama serve && ollama pull nomic-embed-text
#   4. Index papers:            uv run python -m osprey.mcp_server.accelpapers index \
#                                 --data-dir /path/to/inspire/downloads
#
# Environment variables (set in .env):
#   ACCELPAPERS_TYPESENSE_HOST       (default: localhost)
#   ACCELPAPERS_TYPESENSE_PORT       (default: 8108)
#   ACCELPAPERS_TYPESENSE_API_KEY    (default: accelpapers-dev)
#   ACCELPAPERS_COLLECTION           (default: papers)
#   ACCELPAPERS_DATA_DIR             (default data dir for indexing CLI)
#   ACCELPAPERS_OLLAMA_URL           (default: http://localhost:11434)
#   ACCELPAPERS_EMBEDDING_MODEL      (default: openai/nomic-embed-text)

# ============================================================
# CLAUDE CODE INTEGRATION
# ============================================================
# Controls which MCP servers and agents are generated by `osprey claude regen`.
#
# Auto-derived servers (always present unless disabled):
#   controls               (core)
#   python                 (core)
#   workspace              (core)
#   ariel                  (core)
#   accelpapers            (core)
#
# Auto-derived from config sections (present when section exists):
#   confluence: section  → confluence MCP server + wiki-search agent
#   matlab: section      → matlab MCP server + matlab-search agent
#   channel_finder: section → channel-finder MCP server + channel-finder agent
#   deplot: section       → graph tools on workspace + graph-analyst agent
#
# Auto-derived agents (always present unless disabled):
#   logbook-search, logbook-deep-research, literature-search
#
claude_code:
  # servers:                 # Override server settings
  #   accelpapers:
  #     enabled: false       # Disable a framework server
  #   my-server:             # Add a custom MCP server
  #     command: "node"
  #     args: ["my-server.js"]
  #     env:
  #       MY_VAR: "value"
  # agents:                  # Override agent settings
  #   literature-search:
  #     enabled: false       # Disable an agent
  #
  # ── Model Provider ──────────────────────────────────────────
  # Which provider serves Claude models. Must support Anthropic Messages API.
  # Built-in: anthropic (direct), cborg (LBNL proxy), als-apg (ALS AWS proxy)
  # Custom proxy: any name defined under api.providers below
  #   (must have base_url set; uses ANTHROPIC_AUTH_TOKEN + provider model IDs)
  # When set, `osprey claude regen` injects env vars into .claude/settings.json.
  provider: {{ default_provider | default("anthropic") }}
  default_model: {{ default_model | default("haiku") }}   # Options: haiku, sonnet, opus
  #
  # Override model IDs per tier (optional):
  # models:
  #   haiku: anthropic/claude-haiku-alt
  #
  # Override model tier per agent (optional):
  # agent_models:
  #   logbook-search: haiku
  #   logbook-deep-research: sonnet

# ============================================================
# WEB PANEL CONFIGURATION
# ============================================================
# Controls which panel tabs appear in the web terminal (osprey web).
# Universal panels (Workspace, Activity, Session Analytics) are always shown.
# Domain-specific panels are listed here — remove or disable as needed.

web:
  panels:
    ariel:
      enabled: true
    channel-finder:
      enabled: true
    tuning:
      enabled: true
    # Custom panels can be added here:
    # my-grafana:
    #   label: "GRAFANA"
    #   url: "http://grafana.local:3000"
    #   health_endpoint: "/api/health"

# ──────────────────────────────────────────────────────────────────────
# User-Owned Prompt Artifacts
# ──────────────────────────────────────────────────────────────────────
# Claim framework-managed prompt artifacts for in-place editing.
# Regen skips user-owned files, preserving your customizations.
# Run `osprey prompts list` to see all available artifacts.
# Run `osprey prompts claim <name>` to claim an artifact for editing.
#
# prompts:
#   user_owned:
#     - rules/facility    # Auto-claimed on init — edit .claude/rules/facility.md
