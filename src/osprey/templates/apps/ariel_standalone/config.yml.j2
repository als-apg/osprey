# ============================================================
# {{ project_name }} Configuration — ARIEL Standalone
# ============================================================
# Logbook search and research deployment. No control-system runtime;
# no channel finding, no archiver, no Python executor.
# This bundle ships Postgres+pgvector and the ARIEL web/MCP/search stack.
# ============================================================

# Project identity
project_name: "{{ project_name }}"

# Facility identity — substituted into agent prompts (CLAUDE.md, subagents).
# Keep this in sync with .claude/rules/facility.md.
facility_name: "Example Research Facility"

build_dir: ./build

# Root directory (absolute path)
project_root: {{ project_root }}

# ============================================================
# API CONFIGURATION
# ============================================================
# API keys and endpoints for LLM providers. ARIEL references providers
# by name (e.g. "ollama" for embeddings, "{{ default_provider }}" for
# enhancement / composition).

api:
  providers:
    cborg:
      api_key: ${CBORG_API_KEY}
      base_url: https://api.cborg.lbl.gov/v1
      models:
        haiku: claude-haiku-4-5
        sonnet: claude-sonnet-4-6
        opus: claude-opus-4-7
    openai:
      api_key: ${OPENAI_API_KEY}
      base_url: https://api.openai.com/v1
    anthropic:
      api_key: ${ANTHROPIC_API_KEY}
      base_url: https://api.anthropic.com
      models:
        haiku: claude-haiku-4-5-20251001
        sonnet: claude-sonnet-4-5-20250929
        opus: claude-opus-4-6
    google:
      api_key: ${GOOGLE_API_KEY}
      base_url: https://generativelanguage.googleapis.com/v1beta
    ollama:
      api_key: ollama
      base_url: ${OLLAMA_HOST:-http://localhost:11434}
      host: localhost
      port: 11434
    als-apg:
      api_key: ${ALS_APG_API_KEY}
      base_url: https://llm.gianlucamartino.com/v1
      models:
        haiku: claude-haiku-4-5-20251001
        sonnet: claude-sonnet-4-6
        opus: claude-opus-4-6

# ============================================================
# ENVIRONMENT VARIABLES
# ============================================================
# Set these in your .env file:
#
#   ANTHROPIC_API_KEY=sk-ant-...    # or CBORG_API_KEY for the LBL proxy
#   OLLAMA_HOST=http://localhost:11434  # optional: semantic search embeddings
#   TZ=UTC
#

# ============================================================
# CONTAINER RUNTIME
# ============================================================
# Container runtime selection for deployment
# Options: auto (default), docker, podman
container_runtime: auto

# ============================================================
# SYSTEM CONFIGURATION
# ============================================================
system:
  # Facility timezone: ARIEL parses operator-provided times as facility-local
  # and renders all logbook timestamps in this zone (with an explicit offset).
  # Pinned to UTC for reproducibility — set your real facility zone
  # (e.g. America/Los_Angeles) in production. Avoid ${TZ:-...}: inheriting the
  # host $TZ makes logbook queries and rendered timestamps non-deterministic.
  timezone: UTC

# ============================================================
# SERVICE CONFIGURATION
# ============================================================
# Only PostgreSQL is needed for ARIEL logbook search

services:
  postgresql:
    path: ./services/postgresql
    database_name: ariel
    username: ariel
    password: ariel
    port_host: 5432

  # Local telemetry backend for the OSPREY agent — a single-binary OTLP
  # logs/metrics store (see the `telemetry:` block under `claude_code:` below
  # and docs/how-to/monitor-agent.rst). Deployed by default: the agent emits its
  # telemetry here, so `osprey deploy up` + `osprey web` gives you a working,
  # queryable observability store out of the box. Bound to localhost.
  openobserve:
    path: ./services/openobserve
    port: 5080          # Host port for the OpenObserve UI + OTLP ingest
    retention_days: 14  # Growth bound: drop data older than N days (min 3). A
                        # named volume has no size cap, so age is the size knob.

# Services to deploy with `osprey deploy up`
deployed_services:
  - postgresql
  - openobserve

# ============================================================
# SAFETY CONTROLS
# ============================================================

# Approval workflow for sensitive operations
# Policies: always (prompt every time), selective (content-aware), skip (no approval)
approval:
  enabled: true
  default_policy: "always"        # Fail-closed: unknown tools require approval
  tools:
    entry_create: always           # ARIEL logbook entry creation requires approval

# ── Hook observability ──────────────────────────────────────────────
# Set debug: true to enable hook activity logging to stderr.
hooks:
  debug: true

# ============================================================
# ARIEL CONFIGURATION
# ============================================================
# Logbook search service: keyword + semantic search + entry retrieval.
# Higher-level reasoning is owned by the Osprey agent layer; ARIEL itself
# exposes raw search and entry lookup over MCP/HTTP.

ariel:
  database:
    uri: postgresql://ariel:ariel@localhost:5432/ariel

  default_max_results: 10

  # Ingestion - demo logbook data (bundled with template)
  # For production: change adapter and source_url to your logbook system
  ingestion:
    adapter: generic_json
    source_url: data/logbook_seed/demo_logbook.json

  # Search modules (leaf-level search functions)
  # Both keyword and semantic are enabled out of the box.
  # If Ollama/pgvector are unavailable, ARIEL degrades gracefully to keyword-only.
  search_modules:
    keyword:
      enabled: true
    semantic:
      enabled: true      # Degrades gracefully if Ollama/pgvector unavailable
      provider: ollama   # References api.providers.ollama
      model: nomic-embed-text

  # Enhancement modules — run during ingestion
  enhancement_modules:
    # Semantic processor: LLM-based keyword extraction and summarization
    semantic_processor:
      enabled: false                          # Requires LLM API calls
      provider: {{ default_provider }}
      model:
        provider: {{ default_provider }}
        model_id: {{ default_model }}
        max_tokens: 256

    # Text embedding: Vector embeddings for semantic search
    text_embedding:
      enabled: true                           # Degrades gracefully if Ollama/pgvector unavailable
      provider: ollama
      models:
        - name: nomic-embed-text
          dimension: 768

  # Default embedding provider (fallback for modules without explicit provider)
  embedding:
    provider: ollama

# ============================================================
# LOGBOOK COMPOSITION
# ============================================================
# LLM settings for the logbook compose panel in the artifact gallery.

logbook:
  composition:
    provider: {{ default_provider }}
    model_id: {{ default_model | default("haiku") }}
    default_tier: haiku   # Options: haiku | sonnet | opus

# ============================================================
# AGENT DATA & ARTIFACT GALLERY
# ============================================================

agent_data:
  base_dir: "./_agent_data"

artifact_server:
  host: "127.0.0.1"
  port: 8086
  auto_launch: true

# ============================================================
# CLAUDE CODE INTEGRATION
# ============================================================
# In this preset, Claude Code is configured as the logbook-research
# assistant: ARIEL MCP server + workspace MCP server + the
# logbook-deep-research subagent. No control-system MCP servers.

claude_code:
  # Disable the control-system and python-executor MCP servers — this is an
  # ARIEL-only deployment, no hardware writes, no in-process Python sandbox.
  # osprey_workspace and ariel stay enabled (osprey_workspace is required
  # by the logbook-deep-research subagent for artifact handoff).
  servers:
    controls:
      enabled: false
    python:
      enabled: false

  provider: {{ default_provider }}
  default_model: {{ default_model | default("haiku") }}   # Options: haiku, sonnet, opus
  #
  # Override model IDs per tier (optional):
  # models:
  #   haiku: anthropic/claude-haiku-alt
  #
  # Override model tier per agent (optional):
  # agent_models:
  #   logbook-deep-research: sonnet

  # ── Telemetry / Observability (on by default, local + loopback-bound) ──
  # The agent emits OTLP logs + metrics to the co-deployed OpenObserve store
  # (declared in `services:` and listed in `deployed_services:` above; UI at
  # http://localhost:5080). On by default: the underlying harness already records
  # every prompt, response, and API body to disk, so this adds no new exposure —
  # it just makes that data queryable in a local store you own. To turn it off,
  # set `enabled: false`. Tracing and OTEL_LOG_TOOL_CONTENT are intentionally
  # NOT wired. See docs/how-to/monitor-agent.rst.
  telemetry:
    enabled: true                        # Master switch
    backend: openobserve                 # openobserve | generic
    protocol: http/protobuf              # http/protobuf | grpc
    # backend: openobserve auto-derives the endpoint per network context —
    # http://localhost:5080/api/<org> on the host, http://openobserve:5080/api/<org>
    # inside the deploy network — so `endpoint` is intentionally OMITTED here.
    # (Hardcoding localhost would make the in-container dispatch worker emit to
    # its own loopback and silently drop everything.)
    #
    # OpenObserve auth + org routing. user/password read the OpenObserve root
    # credentials from the project .env — the SAME values the openobserve service
    # reads — so container and agent auth stay in sync (single source of truth).
    # `osprey deploy up` mints a strong ZO_ROOT_USER_PASSWORD into .env; the
    # ${VAR:-default} fallbacks keep the agent launchable before the first deploy.
    openobserve:
      user: ${ZO_ROOT_USER_EMAIL:-root@example.com}
      password: ${ZO_ROOT_USER_PASSWORD:-Complexpass#123}
      org: default
    # Content gates — all default ON. The store is local and loopback-bound, so
    # full capture is the default posture; set any to false to suppress that
    # category. (If you rebind the store off localhost, change the default
    # password first — these records include raw API bodies.)
    log_user_prompts: true               # Operator chat prompts
    log_assistant_responses: true        # Agent replies
    log_tool_details: true               # Tool names + arguments
    log_raw_api_bodies: true             # Raw provider request/response bodies

# ============================================================
# WEB PANEL CONFIGURATION
# ============================================================
# Controls which panel tabs appear in the web terminal (osprey web).
# Universal panels (Workspace, Activity, Session Analytics) are always shown.

web:
{%- set _BUILTIN_PANELS = builtin_panels | default(["ariel", "channel-finder"]) %}
{%- set _enabled_builtin_panels = selected_web_panels | select("in", _BUILTIN_PANELS) | list %}
{%- if default_panel is defined and default_panel %}
  # Tab focused on cold load. Falls back to "artifacts" (Workspace) when unset.
  default_panel: {{ default_panel }}
{%- endif %}
{%- if _enabled_builtin_panels %}
  panels:
{%- for panel in _enabled_builtin_panels %}
    {{ panel }}:
      enabled: true
{%- endfor %}
{%- else %}
  panels: {}
{%- endif %}
{%- if panel_presets is defined and panel_presets %}
  # Panel layouts ("Layouts"): named sets of panels a human applies in one click
  # from the web terminal "+" popover. The key is the menu label; the value is
  # the exact set of panels to show (non-member panels close).
  presets:
{%- for preset_name, preset_panels in panel_presets.items() %}
    {{ preset_name | tojson }}: [{{ preset_panels | join(", ") }}]
{%- endfor %}
{%- endif %}
  # Optional panel controls (off by default; uncomment to use):
  #   web.panels.<id>.hidden: true                          # launch the panel but keep its tab hidden until shown
  #   web.allow_runtime_panels: true                        # let the agent register ad-hoc URL panels at runtime
  #   web.runtime_panel_allowlist: ["dashboard.local:3000"] # restrict registration targets to these host[:port]
  #   web.presets:                                          # named "Layouts" a human applies from the "+" popover
  #     "Logbook review": [ariel, artifacts]

# ──────────────────────────────────────────────────────────────────────
# User-Owned Prompt Artifacts
# ──────────────────────────────────────────────────────────────────────
# Claim framework-managed prompt artifacts for in-place editing.
# Regen skips user-owned files, preserving your customizations.
# `rules/facility` is auto-claimed on init — edit .claude/rules/facility.md
# to describe your facility before first use.
