# syntax=docker/dockerfile:1
# Reference container image for {{ project_name }} — generated once by `osprey build`.
# This file is yours: edit it freely or delete it. `osprey claude regen` never
# touches it. To get a fresh copy, rebuild the project with `osprey build`.
#
# Build (from this project directory):   docker build -t {{ project_name }} .
# Run (secrets at runtime — .env is excluded from the image):
#   docker run --rm -p 8087:8087 --env-file .env {{ project_name }}
#
# Build args:
#   OSPREY_PIP_SPEC     pip requirement for OSPREY (default: PyPI release;
#                       override with a git+https URL or ==version to pin an
#                       unreleased build). The deps layer primes this spec with
#                       its dependencies, plus any local dependency delta staged
#                       as osprey-local-requirements.txt on dev builds. If
#                       `osprey deploy up --dev` stages a local *.whl in the
#                       build context, a later wheel layer force-reinstalls
#                       osprey itself from that wheel on top of the primed deps.
#   OSPREY_DEV          "1" relaxes the deps layer: if the pinned OSPREY_PIP_SPEC
#                       is unreleased and fails to install, fall back to the
#                       latest published osprey-framework instead of failing.
#   CLAUDE_CLI_VERSION  Claude Code CLI version to pin (default: this
#                       project's claude_code.cli_version). Bump deliberately
#                       — an unpinned upstream release could silently change
#                       agent behavior between image builds.
#   PIP_NO_PROXY        hosts exempted from any proxy during pip install
#   OSPREY_OFFLINE      "1" vendors web assets into the image (air-gapped hosts)

FROM python:3.12-slim
ARG OSPREY_PIP_SPEC="osprey-framework"
ARG OSPREY_DEV=""
ARG CLAUDE_CLI_VERSION={{ claude_code_cli_version }}
ARG PIP_NO_PROXY=""
ARG OSPREY_OFFLINE="0"

# Debian apt mirrors over HTTPS (plain-HTTP bulk fetches are throttled or
# broken by middleboxes on some networks; deb.debian.org supports HTTPS), and
# bounded apt retries with backoff so a transient network blip mid-build does
# not fail the whole image.
RUN find /etc/apt \( -name '*.sources' -o -name '*.list' \) \
    -exec sed -i 's|http://deb.debian.org|https://deb.debian.org|g' {} + \
 && printf 'Acquire::Retries "5";\n' > /etc/apt/apt.conf.d/80-osprey-retries

RUN apt-get update \
 && apt-get install -y --no-install-recommends curl git procps ca-certificates gnupg \
 && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
 && apt-get install -y --no-install-recommends nodejs \
 && apt-get purge -y gnupg \
 && apt-get autoremove -y \
 && rm -rf /var/lib/apt/lists/*

# Claude Code CLI, pinned via CLAUDE_CLI_VERSION (npm global install) so an
# upstream release cannot silently change agent behavior between image
# builds — mirrors the dispatch-worker image's pinned install.
RUN npm install -g "@anthropic-ai/claude-code@${CLAUDE_CLI_VERSION}"

# OSPREY + profile dependencies (deps layer). A C toolchain (build-essential +
# python3-dev) is needed at install time to compile native deps (e.g.
# accelerator-toolbox); it is purged in the same RUN so it never bloats the
# final image (mirrors the dispatch image). The pinned OSPREY_PIP_SPEC is primed
# here with its dependencies, plus any local dependency delta staged as
# osprey-local-requirements.txt by `osprey deploy up --dev` — installed after
# the primer, while the toolchain is still available. The `.dockerignore` COPY
# sibling keeps the glob matching when no manifest is staged, so the deps cache
# only busts when the manifest content changes. When OSPREY_DEV=1 and the pinned
# spec is unreleased (the primer install fails), fall back to the latest
# published osprey-framework so dev builds are not blocked; otherwise the build
# fails loudly.
COPY .dockerignore osprey-local-requirements.tx[t] /tmp/deps-ctx/
RUN export NO_PROXY="$PIP_NO_PROXY" no_proxy="$PIP_NO_PROXY" \
    && apt-get update \
    && apt-get install -y --no-install-recommends build-essential python3-dev \
    && { pip install --no-cache-dir "$OSPREY_PIP_SPEC" {{ pip_dependency_args | default("") }} \
         || if [ "$OSPREY_DEV" = "1" ]; then \
                echo "WARNING: pin unreleased, priming with latest" \
                && pip install --no-cache-dir osprey-framework {{ pip_dependency_args | default("") }}; \
            else exit 1; fi; } \
    && if [ -f /tmp/deps-ctx/osprey-local-requirements.txt ]; then \
           pip install --no-cache-dir -r /tmp/deps-ctx/osprey-local-requirements.txt; \
       fi \
    && apt-get purge -y build-essential python3-dev \
    && apt-get autoremove -y \
    && rm -rf /var/lib/apt/lists/* /tmp/deps-ctx

# Dev wheel drop (wheel layer). `osprey deploy up --dev` stages a locally-built
# wheel in the build context; when present, reinstall osprey from it (deps
# first, then a --no-deps --force-reinstall so the local build wins over the
# primed copy) and `pip check` the result. With no wheel staged this RUN is a
# no-op (exit 0) and the image is complete after the deps layer. The
# `.dockerignore` sibling in the COPY glob guarantees the COPY always matches at
# least one file, so it never fails when no wheel exists.
COPY .dockerignore *.wh[l] /tmp/ctx/
RUN if ls /tmp/ctx/*.whl >/dev/null 2>&1; then \
        pip install --no-cache-dir /tmp/ctx/*.whl \
        && pip install --no-cache-dir --no-deps --force-reinstall /tmp/ctx/*.whl \
        && pip check; \
    fi \
    && rm -rf /tmp/ctx

# Optional offline mode: vendor web assets (JS/CSS/fonts) into the image so
# the web UI works without internet access. "0" is falsy for is_offline().
RUN if [ "$OSPREY_OFFLINE" = "1" ]; then osprey vendor fetch; fi
ENV OSPREY_OFFLINE=${OSPREY_OFFLINE}

# Project (build context = project root; .dockerignore excludes
# .venv/.env/.git/_agent_data)
COPY . /app/{{ project_name }}/
RUN mkdir -p /app/{{ project_name }}/_agent_data/executed_scripts \
             /app/{{ project_name }}/_agent_data/user_memory \
             /app/{{ project_name }}/_agent_data/api_calls

# Rewrite recorded host paths for the container layout and re-render the
# Claude Code artifacts (.mcp.json, CLAUDE.md, .claude/) against it
RUN osprey claude regen --project /app/{{ project_name }} --runtime-root /app/{{ project_name }}

# Non-root user: Claude Code refuses bypassPermissions mode as root.
RUN useradd --create-home --shell /bin/bash osprey \
 && chown -R osprey:osprey /app/{{ project_name }}
USER osprey
ENV HOME=/home/osprey
WORKDIR /app/{{ project_name }}
EXPOSE 8087
CMD ["osprey", "web", "--host", "0.0.0.0", "--port", "8087", "--project", "/app/{{ project_name }}"]
