# Generated by `osprey build` alongside the reference Dockerfile.
# Keeps secrets and host-specific state out of the container image.

# Secrets — must never enter the image (pass at runtime: --env-file .env)
.env

# Host-specific / regenerable
.venv
.git
_agent_data/
# Regenerated in-image with fresh deploy stamps — excluding it keeps those
# stamps from busting the image cache on every rebuild.
build/
__pycache__/
*.py[cod]
.pytest_cache/
*.log
*.pid
.DS_Store

# Personal (non-shared) Claude Code settings
.claude/settings.local.json
CLAUDE.local.md

# The image doesn't need its own build recipe. Note: .dockerignore itself is
# NOT excluded — the wheel layer's `COPY .dockerignore *.wh[l]` relies on it as a
# guaranteed-present sibling so the COPY never fails when no wheel is staged.
Dockerfile
