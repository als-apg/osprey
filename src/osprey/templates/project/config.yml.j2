# ============================================================
# {{ project_name }} Configuration
# ============================================================
# Claude Code project — streamlined configuration.
# ============================================================

# Project identity
project_name: "{{ project_name }}"

build_dir: ./build

# Root directory (absolute path)
project_root: {{ project_root }}

# ============================================================
# CONTAINER RUNTIME
# ============================================================
# Container runtime selection for deployment
# Options: auto (default), docker, podman
# - auto: Tries Docker first, then Podman
# - docker: Use Docker Desktop (recommended for macOS/Windows)
# - podman: Use Podman (recommended for Linux/security-focused)
# Can also override via CONTAINER_RUNTIME environment variable

container_runtime: auto

# ============================================================
# SERVICE CONFIGURATION
# ============================================================
# Containerized companion services. Declare a service under `services:` (so
# `osprey health` recognizes it) and add its name to `deployed_services:` to
# actually launch it with `osprey deploy up`.

{% if deploy_services | default(true) %}
services:
  # Local telemetry backend for the OSPREY agent — a single-binary OTLP
  # logs/metrics store (see the `telemetry:` block under `claude_code:` below
  # and docs/how-to/monitor-agent.rst). Deployed by default: the agent emits its
  # telemetry here, so `osprey deploy up` + `osprey web` gives you a working,
  # queryable observability store out of the box. Bound to localhost.
  openobserve:
    path: ./services/openobserve
    port: 5080          # Host port for the OpenObserve UI + OTLP ingest
    retention_days: 14  # Growth bound: drop data older than N days (min 3). A
                        # named volume has no size cap, so age is the size knob.

# Services launched by `osprey deploy up`.
deployed_services:
  - openobserve
{% else %}
# Attached project (deploy_services: false): connects to a services stack
# another OSPREY project deployed on the same host, so it scaffolds nothing.
services: {}

deployed_services: []
{% endif %}

# ============================================================
# SAFETY CONTROLS
# ============================================================

# Approval workflow for sensitive operations
# Policies: always (prompt every time), selective (content-aware), skip (no approval)
approval:
  enabled: true
  default_policy: "always"        # Fail-closed: unknown tools require approval
  tools:
    channel_write: always          # Always prompt for hardware writes
    channel_read: skip             # Read-only, no approval needed
    channel_limits: skip           # Read-only safety metadata, no approval needed
    archiver_read: skip            # Historical data, no approval needed
    execute: selective             # Content-aware: checks write patterns + exec mode
    setup_patch: always            # Config mutation needs approval
    entry_create: always           # ARIEL logbook write

# ============================================================
# SYSTEM CONFIGURATION
# ============================================================

system:
  # Facility timezone: how the agent interprets operator-provided times
  # (parsed as facility-local) and renders all timestamps (with an explicit
  # offset). Pinned to UTC for reproducibility — set your real facility zone
  # (e.g. America/Los_Angeles) in production. Avoid ${TZ:-...}: inheriting the
  # host $TZ makes archiver queries and simulated events non-deterministic.
  timezone: UTC

# File paths - Data storage organization
file_paths:
  agent_data_dir: _agent_data
  executed_python_scripts_dir: executed_scripts
  user_memory_dir: user_memory
  api_calls_dir: api_calls

# ============================================================
# EXECUTION INFRASTRUCTURE
# ============================================================

# Python execution configuration
execution:
  execution_method: "local"              # Options: local | container
  python_env_path: {{ current_python_env }}  # Path to Python with dependencies


# ============================================================
# CONTROL SYSTEM CONFIGURATION
# ============================================================
# Control system type, write access, limits checking, and verification
# Default: mock connector (no hardware required, safe for development)

control_system:
  # Control system type - determines which runtime connector to use
  # Note: Pattern detection is control-system-agnostic (same for all types)
  type: "mock"  # Options: mock | epics

  # Write Access Control - Master safety switch
  writes_enabled: false  # Set true only for production hardware control
  # write_tools:                # Additional tools blocked by writes kill switch
  #   - "mcp__my_server__dangerous_write"

  # Runtime Channel Limits Checking
  limits_checking:
    enabled: false  # Enable for production safety
    database_path: null  # Path to channel_limits.json
    allow_unlisted_channels: true

  # Write Verification Configuration
  write_verification:
    enabled: false  # Enable verification for production
    default_level: "callback"  # Options: none | callback | readback
    default_tolerance_percent: 0.1
    timeout: 5.0
    fail_on_mismatch: false

  # Connector-specific configuration
  connector:
    mock:
      simulate_delays: false
    epics:
      timeout: 5.0
      gateways:
        read_only:
          address: your-gateway.example.com  # Replace with your EPICS gateway address
          port: 5064
          use_name_server: false  # Set true for SSH tunnels
        write_access:
          address: your-gateway.example.com  # Replace with your EPICS gateway address
          port: 5084
          use_name_server: false

  # Pattern Detection (Security Layer)
  # Purpose: Detect ALL control system operations for approval workflows
  # Security: Catches approved API AND circumvention attempts (direct library calls)
  # Framework Default: Detects osprey.runtime API + EPICS/Tango/LabVIEW direct calls
  # Custom patterns EXTEND framework defaults by default.
  # Set mode: override to replace framework patterns entirely.
  # patterns:
  #   mode: extend    # extend (default) | override
  #   write: ['my_custom_cs_lib\.write\(']
  #   read: ['my_custom_cs_lib\.read\(']

  # Runtime Connectors
  # Used by: Capabilities and osprey.runtime API
  # Purpose: Actual I/O operations with built-in safety features

# ============================================================
# CLAUDE CODE CONFIGURATION
# ============================================================
# Controls `osprey claude regen` behavior.
# Agents are auto-managed based on config and are not listed here.

claude_code:
  # ── CLI Version Pin (issue #218) ──────────────────────────
  # Pin the Claude Code CLI version to insulate this project from upstream
  # breaking releases. When set, `osprey claude chat` and `osprey web` launch
  # via `npx -y @anthropic-ai/claude-code@<version>` instead of bare `claude`.
  # First run downloads the package; subsequent runs hit the npx cache.
  # Verify with `osprey health` after setting.
  # cli_version: "2.1.146"
  #
  # ── Server / Agent Overrides ──────────────────────────────
  # Disable framework servers or add custom MCP servers:
  # servers:
  #   accelpapers:
  #     enabled: false
  #   my-server:
  #     command: "python"
  #     args: ["-m", "my_mcp"]
  #     env:
  #       MY_KEY: "${MY_KEY}"
  #     hooks:
  #       pre_tool_use: [approval]       # Human approval for all tools
  #     permissions:
  #       allow: [read_data, list_items]
  #       ask: [write_data]
  #
  # Override framework agents or define custom agents:
  # agents:
  #   literature-search:
  #     enabled: false
  #   my-custom-agent:
  #     description: "Searches the facility's custom database."
  #     condition: my_feature        # Only enabled when my_feature is truthy in config
  #     server_dependency: my-server # Only enabled when my-server is active
  #
  # ── Model Provider ──────────────────────────────────────────
  # Which provider serves Claude models. Must support Anthropic Messages API.
  # Built-in: anthropic (direct), cborg (LBNL proxy)
  # Custom proxy: any name defined under api.providers below
  #   (must have base_url set; uses ANTHROPIC_AUTH_TOKEN + cborg-style model IDs)
  # When set, `osprey claude regen` injects env vars into .claude/settings.json.
  provider: {{ default_provider }}
  default_model: {{ default_model | default("haiku") }}   # Options: haiku, sonnet, opus
  #
  # Override model IDs per tier (optional):
  # models:
  #   haiku: anthropic/claude-haiku-alt
  #
  # Override model tier per agent (optional):
  # agent_models:
  #   logbook-search: haiku
  #   logbook-deep-research: sonnet
  #
  # ── Telemetry / Observability (on by default, local + loopback-bound) ──
  # The agent emits OTLP logs + metrics to the co-deployed OpenObserve store
  # (declared in `services:` and listed in `deployed_services:` above; UI at
  # http://localhost:5080). On by default: the underlying harness already records
  # every prompt, response, and API body to disk, so this adds no new exposure —
  # it just makes that data queryable in a local store you own. To turn it off,
  # set `enabled: false`. Tracing and OTEL_LOG_TOOL_CONTENT are intentionally
  # NOT wired. See docs/how-to/monitor-agent.rst.
  telemetry:
    enabled: true                        # Master switch
    backend: openobserve                 # openobserve | generic
    protocol: http/protobuf              # http/protobuf | grpc
    # backend: openobserve auto-derives the endpoint per network context —
    # http://localhost:5080/api/<org> on the host, http://openobserve:5080/api/<org>
    # inside the deploy network — so `endpoint` is intentionally OMITTED here.
    # (Hardcoding localhost would make the in-container dispatch worker emit to
    # its own loopback and silently drop everything. For a GENERIC OTLP backend
    # instead, set backend: generic and endpoint: ${OTEL_EXPORTER_OTLP_ENDPOINT}.)
    #
    # OpenObserve auth + org routing. user/password read the OpenObserve root
    # credentials from the project .env — the SAME values the openobserve service
    # reads — so container and agent auth stay in sync (single source of truth).
    # `osprey deploy up` mints a strong ZO_ROOT_USER_PASSWORD into .env; the
    # ${VAR:-default} fallbacks keep the agent launchable before the first deploy.
    openobserve:
      user: ${ZO_ROOT_USER_EMAIL:-root@example.com}
      password: ${ZO_ROOT_USER_PASSWORD:-Complexpass#123}
      org: default
    # Content gates — all default ON. The store is local and loopback-bound, so
    # full capture is the default posture; set any to false to suppress that
    # category. (If you rebind the store off localhost, change the default
    # password first — these records include raw API bodies.)
    log_user_prompts: true               # Operator chat prompts
    log_assistant_responses: true        # Agent replies
    log_tool_details: true               # Tool names + arguments
    log_raw_api_bodies: true             # Raw provider request/response bodies

# ============================================================
# WEB TERMINAL CONFIGURATION
# ============================================================
# Browser-based Web Terminal UI. Independent of the CLI's `cli.theme` below
# (console-only) — the two never share a value.

web:
  # Default web UI theme: a theme FAMILY (e.g. "osprey", "high-contrast") or
  # a concrete theme id (e.g. "high-contrast-light") to pin a specific mode.
  # A user's in-browser choice (switcher selection, ?theme=, localStorage)
  # always overrides this default. An unknown value falls back to "osprey".
  theme: osprey

# ============================================================
# CLI CONFIGURATION
# ============================================================
# Customize the command-line interface appearance

cli:
  # Theme selection - Options: default | vulcan | custom
  theme: "default"

  # Custom theme colors (only used when theme: custom)
  # Uncomment and modify to create your own color scheme
  # custom_theme:
  #   primary: "#C75F71"     # Main brand color
  #   success: "#9988A1"     # Success messages
  #   accent: "#F0B8B8"      # Interactive elements
  #   command: "#9988A1"     # Shell commands
  #   path: "#A2AE9D"        # File paths
  #   info: "#9988A1"        # Info messages

  # Custom ASCII banner (optional)
  # Uncomment to override the default Osprey banner
  # banner: |
  #   Your custom ASCII art here


# Note: Theme system logging uses the existing 'base' logger color
# No additional logging configuration needed
# ============================================================
# API PROVIDERS
# ============================================================

api:
  providers:
    cborg:
      api_key: ${CBORG_API_KEY}
      base_url: https://api.cborg.lbl.gov/v1
      models:                        # Model IDs as named by this provider
        haiku: claude-haiku-4-5
        sonnet: claude-sonnet-4-6
        opus: claude-opus-4-7
    amsc-i2:
      api_key: ${AMSC_I2_API_KEY}
      base_url: https://api.i2-core.american-science-cloud.org/v1
      models:                        # Model IDs as named by this provider
        haiku: claude-haiku
        sonnet: claude-sonnet
        opus: claude-opus
    stanford:
      api_key: ${STANFORD_API_KEY}
      base_url: https://aiapi-prod.stanford.edu/v1
    openai:
      api_key: ${OPENAI_API_KEY}
      base_url: https://api.openai.com/v1
    anthropic:
      api_key: ${ANTHROPIC_API_KEY}
      base_url: https://api.anthropic.com
      models:
        haiku: claude-haiku-4-5-20251001
        sonnet: claude-sonnet-4-5-20250929
        opus: claude-opus-4-6
    google:
      api_key: ${GOOGLE_API_KEY}
      base_url: https://generativelanguage.googleapis.com/v1beta
    ollama:
      api_key: ollama
      base_url: http://localhost:11434
      host: localhost
      port: 11434
    argo:
      api_key: ${ARGO_API_KEY}
      base_url: https://argo-bridge.cels.anl.gov
    als-apg:
      api_key: ${ALS_APG_API_KEY}
      base_url: https://llm.gianlucamartino.com/v1
      models:
        haiku: claude-haiku-4-5-20251001
        sonnet: claude-sonnet-4-6
        opus: claude-opus-4-6
    # DwarfStar (ds4) — local DeepSeek V4 server (https://github.com/antirez/ds4)
    # No API key required. If the server runs on a remote host, forward the port:
    #   ssh -L 8000:127.0.0.1:8000 <host>
    ds4:
      api_key: EMPTY                  # ds4 ignores auth; any non-empty string works
      base_url: http://127.0.0.1:8000/v1
      # ds4 serves two model sizes; mapped onto the standard tiers so ds4 is a
      # drop-in (flash = fast/cheap tier, pro = capable tiers).
      models:
        haiku: deepseek-v4-flash
        sonnet: deepseek-v4-pro
        opus: deepseek-v4-pro
    # Custom Anthropic-compatible proxy example:
    # my-proxy:
    #   api_key: ${MY_PROXY_API_KEY}   # Set ANTHROPIC_AUTH_TOKEN to this in your shell
    #   base_url: https://your-proxy.example.com
    # Then set claude_code.provider: my-proxy above.

# ============================================================
# ENVIRONMENT VARIABLES
# ============================================================
# Set these in your .env file:
#
#   CBORG_API_KEY=your-cborg-key
#   AMSC_I2_API_KEY=your-amsc-key
#   STANFORD_API_KEY=...
#   ARGO_API_KEY=your-argo-key
#   OPENAI_API_KEY=sk-...
#   ANTHROPIC_API_KEY=sk-ant-...
#   GOOGLE_API_KEY=...
#   PROJECT_ROOT={{ project_root | default("/path/to/project") }}
#   LOCAL_PYTHON_VENV=/path/to/venv/bin/python
#   TZ=UTC
