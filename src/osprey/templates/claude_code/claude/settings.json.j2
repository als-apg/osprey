{%- set ns = namespace() -%}
{
{%- if claude_code_model_spec is defined and claude_code_model_spec is not none %}
  "env": {
{%- for key, value in claude_code_model_spec.env_block.items() %}
    "{{ key }}": "{{ value }}"{% if not loop.last %},{% endif %}
{%- endfor %}
  },
  "model": "{{ claude_code_model_spec.tier_to_model[claude_code_model_spec.default_model_tier] }}",
{%- endif %}
  "outputStyle": ".claude/output-styles/control-operator.md",
  "_PROMPT_PROVIDER_NOTE": "PROMPT-PROVIDER: section=permissions_policy. Future: source from FrameworkPromptProvider.get_permissions_policy(). Facility-customizable: allow/deny/ask tool lists, file access paths, additional facility-specific tools or restrictions.",
  "permissions": {
    "allow": [
{#- Build allow list from server registry -#}
{%- set allow_entries = [] -%}
{%- set _ = allow_entries.append('"Read(_agent_data/**)"') -%}
{%- set _ = allow_entries.append('"Read(osprey-workspace/data/**)"') -%}
{%- set _ = allow_entries.append('"Read(osprey-workspace/plots/**)"') -%}
{%- set _ = allow_entries.append('"Read(osprey-workspace/results/**)"') -%}
{#- Per-server tool permissions -#}
{%- for s in servers if s.enabled -%}
{%- for tool in s.permissions_allow -%}
{%- set _ = allow_entries.append('"mcp__' ~ s.name ~ '__' ~ tool ~ '"') -%}
{%- endfor -%}
{%- for entry in s.fixed_allow -%}
{%- set _ = allow_entries.append('"' ~ entry ~ '"') -%}
{%- endfor -%}
{%- endfor -%}
{%- set _ = allow_entries.append('"NotebookEdit(osprey-workspace/artifacts/**)"') -%}
{#- Per-agent Task() permissions -#}
{%- for a in agents if a.enabled -%}
{%- set _ = allow_entries.append('"Task(' ~ a.name ~ ')"') -%}
{%- endfor -%}
{% for entry in allow_entries %}      {{ entry }}{% if not loop.last %},{% endif %}
{% endfor %}    ],
    "deny": [
      "Bash",
      "Edit",
      "WebFetch",
      "WebSearch",
      "mcp__plugin_playwright_playwright__*",
      "mcp__plugin_context7_context7__*"
    ],
    "ask": [
{%- set ask_entries = [] -%}
{%- for s in servers if s.enabled -%}
{%- for tool in s.permissions_ask -%}
{%- set _ = ask_entries.append('"mcp__' ~ s.name ~ '__' ~ tool ~ '"') -%}
{%- endfor -%}
{%- for entry in s.fixed_ask -%}
{%- set _ = ask_entries.append('"' ~ entry ~ '"') -%}
{%- endfor -%}
{%- endfor -%}
{% for entry in ask_entries %}      {{ entry }}{% if not loop.last %},{% endif %}
{% endfor %}    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat \"$CLAUDE_PROJECT_DIR/osprey-workspace/focus_state.txt\" 2>/dev/null || true",
            "timeout": 1
          }
        ]
      }
    ],
    "PreToolUse": [
{%- set pre_rules = [] -%}
{%- for s in servers if s.enabled -%}
{%- for rule in s.hooks_pre -%}
{%- set _ = pre_rules.append(rule) -%}
{%- endfor -%}
{%- endfor -%}
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/osprey_memory_guard.py\"",
            "timeout": 5
          }
        ]
      }{% if pre_rules %},{% endif %}
{%- for rule in pre_rules %}
      {
        "matcher": "{{ rule.matcher }}",
        "hooks": [
{%- for h in rule.hooks %}
          {
            "type": "{{ h.type }}",
            "command": {{ h.command | tojson }},
            "timeout": {{ h.timeout }}
          }{% if not loop.last %},{% endif %}
{%- endfor %}
        ]
      }{% if not loop.last %},{% endif %}
{%- endfor %}
    ],
    "PostToolUse": [
{%- set post_rules = [] -%}
{%- for s in servers if s.enabled -%}
{%- for rule in s.hooks_post -%}
{%- set _ = post_rules.append(rule) -%}
{%- endfor -%}
{%- endfor -%}
{%- for rule in post_rules %}
      {
        "matcher": "{{ rule.matcher }}",
        "hooks": [
{%- for h in rule.hooks %}
          {
            "type": "{{ h.type }}",
            "command": {{ h.command | tojson }},
            "timeout": {{ h.timeout }}
          }{% if not loop.last %},{% endif %}
{%- endfor %}
        ]
      },
{%- endfor %}
      {
        "matcher": "NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/osprey_notebook_update.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
