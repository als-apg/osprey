{
  "_PROMPT_PROVIDER_NOTE": "PROMPT-PROVIDER: section=permissions_policy. Future: source from FrameworkPromptProvider.get_permissions_policy(). Facility-customizable: allow/deny/ask tool lists, file access paths, additional facility-specific tools or restrictions.",
  "permissions": {
    "allow": [
      "Read(_agent_data/**)",
      "Read(osprey-workspace/data/**)",
      "Read(osprey-workspace/memory/**)",
      "Read(osprey-workspace/plots/**)",
      "Read(osprey-workspace/results/**)",
{% if "osprey-control-system" not in disable_servers %}      "mcp__osprey-control-system__channel_read",
      "mcp__osprey-control-system__archiver_read",
{% endif %}{% if "osprey-workspace" not in disable_servers %}      "mcp__osprey-workspace__memory_recall",
      "mcp__osprey-workspace__screenshot_capture",
      "mcp__osprey-workspace__list_windows",
      "mcp__osprey-workspace__manage_window",
      "mcp__osprey-workspace__submit_response",
      "mcp__osprey-workspace__data_context_list",
      "mcp__osprey-workspace__artifact_focus",
{% endif %}{% if "ariel" not in disable_servers %}      "mcp__ariel__ariel_keyword_search",
      "mcp__ariel__ariel_semantic_search",
      "mcp__ariel__ariel_sql_query",
      "mcp__ariel__ariel_entries_by_ids",
      "mcp__ariel__ariel_browse",
      "mcp__ariel__ariel_entry_get",
      "mcp__ariel__ariel_capabilities",
      "mcp__ariel__ariel_status",
      "mcp__ariel__ariel_filter_options",
{% endif %}      "NotebookEdit(osprey-workspace/artifacts/**)",
{% if "channel-resolver" not in disable_agents and channel_finder_pipeline is defined %}      "Task(channel-resolver)",
{% endif %}{% if "logbook-search" not in disable_agents %}      "Task(logbook-search)",
{% endif %}{% if "logbook-deep-research" not in disable_agents %}      "Task(logbook-deep-research)",
{% endif %}{% if "literature-search" not in disable_agents %}      "Task(literature-search)",
{% endif %}{% if "accelpapers" not in disable_servers %}      "mcp__accelpapers__papers_search",
      "mcp__accelpapers__papers_get",
      "mcp__accelpapers__papers_browse",
      "mcp__accelpapers__papers_list_conferences",
      "mcp__accelpapers__papers_search_author",
      "mcp__accelpapers__papers_stats",
{% endif %}{% if matlab is defined and "matlab" not in disable_servers %}      "mcp__matlab__mml_search",
      "mcp__matlab__mml_get",
      "mcp__matlab__mml_browse",
      "mcp__matlab__mml_dependencies",
      "mcp__matlab__mml_path",
      "mcp__matlab__mml_list_groups",
      "mcp__matlab__mml_stats",
{% endif %}{% if matlab is defined and "matlab-search" not in disable_agents %}      "Task(matlab-search)",
{% endif %}{% if channel_finder_pipeline is defined and "channel-finder" not in disable_servers %}      "mcp__channel-finder",
{% endif %}{% if confluence is defined and "confluence" not in disable_servers %}      "mcp__confluence",
{% endif %}{% if confluence is defined and "wiki-search" not in disable_agents %}      "Task(wiki-search)",
{% endif %}      "_sentinel_allow"
    ],
    "deny": [
      "Bash",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch",
      "mcp__plugin_playwright_playwright__*",
      "mcp__plugin_context7_context7__*"
    ],
    "ask": [
{% if "osprey-control-system" not in disable_servers %}      "mcp__osprey-control-system__channel_write",
{% endif %}{% if "osprey-python-executor" not in disable_servers %}      "mcp__osprey-python-executor__python_execute",
{% endif %}{% if "osprey-workspace" not in disable_servers %}      "mcp__osprey-workspace__memory_save",
      "mcp__osprey-workspace__artifact_save",
{% endif %}{% if "ariel" not in disable_servers %}      "mcp__ariel__ariel_entry_create",
{% endif %}{% for name in extra_servers %}{% if name not in disable_servers %}      "mcp__{{ name }}",
{% endif %}{% endfor %}      "_sentinel_ask"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat \"$CLAUDE_PROJECT_DIR/osprey-workspace/focus_state.txt\" 2>/dev/null || true",
            "timeout": 1
          }
        ]
      }
    ],
    "PreToolUse": [
{% if "osprey-control-system" not in disable_servers %}      {
        "matcher": "mcp__osprey-control-system__channel_write",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/osprey_writes_check.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/osprey_limits.py\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/osprey_approval.py\"",
            "timeout": 5
          }
        ]
      },
{% endif %}{% if "osprey-python-executor" not in disable_servers %}      {
        "matcher": "mcp__osprey-python-executor__python_execute",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/osprey_writes_check.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/osprey_approval.py\"",
            "timeout": 5
          }
        ]
      },
{% endif %}      {"_sentinel_pre": true}
    ],
    "PostToolUse": [
{% if "osprey-control-system" not in disable_servers %}      {
        "matcher": "mcp__osprey-control-system__*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/osprey_error_guidance.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/osprey_audit.py\"",
            "timeout": 5
          }
        ]
      },
{% endif %}{% if "osprey-python-executor" not in disable_servers %}      {
        "matcher": "mcp__osprey-python-executor__*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/osprey_error_guidance.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/osprey_audit.py\"",
            "timeout": 5
          }
        ]
      },
{% endif %}{% if "osprey-workspace" not in disable_servers %}      {
        "matcher": "mcp__osprey-workspace__*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/osprey_error_guidance.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/osprey_audit.py\"",
            "timeout": 5
          }
        ]
      },
{% endif %}{% if "ariel" not in disable_servers %}      {
        "matcher": "mcp__ariel__*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/osprey_error_guidance.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/osprey_audit.py\"",
            "timeout": 5
          }
        ]
      },
{% endif %}{% if "accelpapers" not in disable_servers %}      {
        "matcher": "mcp__accelpapers__*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/osprey_error_guidance.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/osprey_audit.py\"",
            "timeout": 5
          }
        ]
      },
{% endif %}{% if matlab is defined and "matlab" not in disable_servers %}      {
        "matcher": "mcp__matlab__*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/osprey_error_guidance.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/osprey_audit.py\"",
            "timeout": 5
          }
        ]
      },
{% endif %}      {
        "matcher": "NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/osprey_notebook_update.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
