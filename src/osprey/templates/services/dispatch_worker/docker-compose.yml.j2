# The dispatch-worker runs the full PROJECT image (<project>:local) that
# `osprey deploy up` builds from the project root — the same image the web
# terminal runs, baking the facility overlays and data/ into /app/<project>.
# It overrides only `command:` to launch the dispatch-worker MCP server instead
# of the web UI. OSPREY_WORKER_IMAGE overrides with a prebuilt/published image.
#
# NOTE: Multi-worker load distribution is NOT yet implemented.
# The dispatcher routes to dispatch-worker-1 only (hardcoded in tutorial_triggers.yml dispatch_target).
# Additional workers declared here are provisioned but idle until routing is implemented.
{% set wc = services.dispatch_worker.worker_count | default(1) %}
{% set mode = services.dispatch_worker.workspace_mode | default('isolated') %}

services:
{% for i in range(1, wc + 1) %}
  dispatch-worker-{{ i }}:
    image: ${OSPREY_WORKER_IMAGE:-{{ services.dispatch_worker.image | default('osprey-dispatch:local') }}}
    # NO build: block here on purpose. The project image (<project>:local) is
    # built once by `osprey deploy up` (deployment/container_lifecycle.py) from
    # the project root before `docker compose up` runs; the worker just
    # references that prebuilt tag. Declaring a second `build:` for it would race
    # the sole builder to tag the same image. `depends_on` keeps the worker
    # ordered after the event-dispatcher. A prebuilt OSPREY_WORKER_IMAGE override
    # is pulled normally instead.
    depends_on:
      - event-dispatcher
    container_name: osprey-dispatch-worker-{{ i }}
    command: ["python", "-m", "osprey.mcp_server.dispatch_worker"]
    labels:
      osprey.project.name: "{{ osprey_labels.project_name }}"
      osprey.project.root: "{{ osprey_labels.project_root }}"
      osprey.deployed.at: "{{ osprey_labels.deployed_at }}"
    restart: unless-stopped
{% if osprey_env_present | default(false) %}
    # Provider auth: the worker's startup hook (inject_provider_env) resolves
    # the LLM provider key (e.g. ALS_APG_API_KEY -> ANTHROPIC_AUTH_TOKEN) from
    # the process environment. `env_file:` is read by the compose CLI on the
    # HOST (as the file's owner), so it works even though the project .env is
    # deliberately 0600 and the worker itself runs as non-root `osprey` and
    # cannot open it. Path is relative to the compose project directory
    # (build/services/, same resolution rule as `volumes:` bind sources) — see
    # the `../../.env` volume path elsewhere in this repo for the same prefix.
    env_file:
      - ../../.env
{% endif %}
    environment:
      # No :-default (see event_dispatcher compose): fail closed on an unset token.
      DISPATCH_WORKER_TOKEN: ${DISPATCH_WORKER_TOKEN}
      DISPATCH_WORKER_PORT: "{{ services.dispatch_worker.worker_port_base | default(9190) }}"
      DISPATCH_TIMEOUT_SEC: "{{ services.dispatch_worker.timeout_sec | default(300) }}"
      OSPREY_PROJECT_DIR: /app/{{ osprey_labels.project_name }}
      # The worker process reads OSPREY config directly (e.g. get_facility_timezone
      # while building the agent's system prompt), and spawns a CLI subprocess with
      # its own MCP servers. Set CONFIG_FILE explicitly so the worker AND every
      # subprocess resolve config from the mounted project (via env inheritance),
      # independent of CWD. It points at the STAGED config.yml bind-mounted below
      # (python_env_path stripped), not the copy baked into the image.
      CONFIG_FILE: /app/{{ osprey_labels.project_name }}/config.yml
      TZ: {{ system.timezone }}
    # Bind-mount source is relative to the compose project directory
    # (build/services/), not this service's subdir — hence the dispatch_worker/ prefix.
    volumes:
      # Staged runtime config (python_env_path stripped) overlays the config.yml
      # baked into the image, so the worker reads the deploy-time config.
      - ./dispatch_worker/config.yml:/app/{{ osprey_labels.project_name }}/config.yml:ro
      # The image creates /app/<project>/_agent_data (and its subdirs) and
      # `chown -R osprey:osprey /app/<project>` before switching to USER osprey,
      # so a fresh named volume initialized from that path inherits osprey
      # ownership — the non-root worker can write it without any user: override.
{% if mode == 'shared' %}
      - dispatch_workspace:/app/{{ osprey_labels.project_name }}/_agent_data
{% else %}
      - dispatch_workspace_{{ i }}:/app/{{ osprey_labels.project_name }}/_agent_data
{% endif %}
    networks:
      - osprey-network
    healthcheck:
      test: ["CMD-SHELL", "python -c \"import urllib.request,sys; sys.exit(0 if urllib.request.urlopen('http://localhost:{{ services.dispatch_worker.worker_port_base | default(9190) }}/health').status==200 else 1)\""]
      interval: 10s
      timeout: 5s
      retries: 5
      # Grace period before failed probes count — first run provisions Claude
      # artifacts and injects provider env, which takes a few seconds.
      start_period: 30s
{% endfor %}

volumes:
{% if mode == 'shared' %}
  dispatch_workspace:
{% else %}
{% for i in range(1, wc + 1) %}
  dispatch_workspace_{{ i }}:
{% endfor %}
{% endif %}

networks:
  osprey-network:
